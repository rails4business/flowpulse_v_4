<% content_for :title, "Blog Flowpulse" %>

<section class="home-shell">
  <nav class="top-nav">
    <%= link_to root_path, class: "brand-mark" do %>
      <%= image_tag "flowpulse_brand.png", alt: "Flowpulse", class: "brand-logo" %>
      <span>Flowpulse</span>
    <% end %>

    <div class="top-nav-links">
      <a href="<%= root_path %>#struttura">Struttura</a>
      <a href="<%= root_path %>#journey">Journey</a>
      <%= link_to "About", about_path %>
      <%= link_to "Blog", blog_path %>

      <% if authenticated? %>
        <details class="user-menu">
          <summary class="user-trigger">
            <span class="user-avatar"><%= Current.session.user.email_address.first.upcase %></span>
          </summary>

          <div class="user-dropdown">
            <% if Current.session.user.profile.present? %>
              <%= link_to "Home", root_path %>
              <%= link_to "Dashboard", dashboard_path %>
              <%= link_to "Profilo", edit_profile_path(anchor: "profile-main") %>
              <%= link_to "Impostazioni", edit_profile_path(anchor: "profile-settings") %>
            <% else %>
              <%= link_to "Home", root_path %>
              <%= link_to "Completa profilo", new_profile_path %>
            <% end %>

            <%= button_to "Esci", session_path, method: :delete, class: "user-menu-button" %>
          </div>
        </details>
      <% else %>
        <%= link_to "Registrati", new_registration_path %>
        <%= link_to "Accedi", new_session_path, class: "nav-login" %>
      <% end %>
    </div>
  </nav>

  <section class="blog-index-header">
    <p class="eyebrow">Blog</p>
    <h2 class="blog-index-title">Appunti, visione e sviluppo di Flowpulse.</h2>
    <p class="blog-index-intro">
      Una raccolta pubblica di note, idee e passaggi di costruzione letti direttamente dai file markdown del progetto.
    </p>
    <hr class="blog-index-rule">
  </section>

  <section class="blog-index-shell">
    <ul class="blog-index-list" id="post-list">
      <% @posts.each do |post| %>
        <li class="blog-index-item">
          <div class="blog-index-date">
            <p><%= l(post.published_on, format: :long) if post.published_on %></p>
          </div>

          <div class="blog-index-copy">
            <h3 class="blog-index-item-title">
              <%= link_to post.title, blog_post_path(post.slug), class: "blog-card-link" %>
            </h3>
            <p class="blog-index-excerpt"><%= post.excerpt %></p>
          </div>
        </li>
      <% end %>
    </ul>
  </section>
</section>
