<% content_for :title, "Blog Flowpulse" %>

<section style="min-height: 100vh; background: #ffffff;">
  <%= render "shared/public_nav",
    brand_title: "Flowpulse",
    logo_horizontal_url: asset_path("flowpulse_brand.png"),
    home_path: root_path,
    accent_color: "#c96f38",
    background_color: "#ffffff",
    header_bg_color: "#ffffff",
    header_text_color: "#1d1f1e",
    nav_links: @public_nav_links %>

  <div class="home-shell">
  <section class="blog-index-header">
    <p class="eyebrow">Blog</p>
    <h2 class="blog-index-title">Appunti, visione e sviluppo di Flowpulse.</h2>
    <p class="blog-index-intro">
      Una raccolta pubblica di note, idee e passaggi di costruzione letti direttamente dai file markdown del progetto.
    </p>
    <hr class="blog-index-rule">
  </section>

  <section class="blog-index-shell">
    <ul class="blog-index-list" id="post-list">
      <% @posts.each do |post| %>
        <li class="blog-index-item">
          <div class="blog-index-date">
            <p><%= l(post.published_on, format: :long) if post.published_on %></p>
          </div>

          <div class="blog-index-copy">
            <h3 class="blog-index-item-title">
              <%= link_to post.title, blog_post_path(post.slug), class: "blog-card-link" %>
            </h3>
            <p class="blog-index-excerpt"><%= post.excerpt %></p>
          </div>
        </li>
      <% end %>
    </ul>
  </section>
  </div>
</section>
