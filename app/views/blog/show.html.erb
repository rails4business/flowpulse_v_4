<% content_for :title, @post.title %>

<section style="min-height: 100vh; background: #ffffff;">
  <%= render "shared/public_nav",
    brand_title: "Flowpulse",
    logo_horizontal_url: asset_path("flowpulse_brand.png"),
    home_path: root_path,
    accent_color: "#c96f38",
    background_color: "#ffffff",
    header_bg_color: "#ffffff",
    header_text_color: "#1d1f1e",
    nav_links: @public_nav_links %>

  <div class="home-shell">
  <article class="wide-card blog-post">
    <p class="eyebrow">Blog</p>
    <h1 class="blog-post-title"><%= @post.title %></h1>
    <% if @post.published_on %>
      <p class="blog-post-date"><%= l(@post.published_on, format: :long) %></p>
    <% end %>

    <div class="blog-content">
      <%= render_markdown(@post.body) %>
    </div>
  </article>
  </div>
</section>
