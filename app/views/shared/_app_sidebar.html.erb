<div class="app-sidebar-shell" data-controller="sidebar">
  <button type="button" class="app-sidebar-toggle" data-action="sidebar#open" aria-label="Apri menu laterale">
    <span class="app-sidebar-toggle-icon">☰</span>
    <span>Menu</span>
  </button>
  <button type="button" class="app-sidebar-overlay" data-sidebar-target="overlay" data-action="sidebar#close" aria-label="Chiudi menu"></button>

  <aside class="app-sidebar" data-sidebar-target="panel">
    <div class="app-sidebar-mobile-head">
      <span>Menu</span>
      <button type="button" class="app-sidebar-close" data-action="sidebar#close" aria-label="Chiudi">×</button>
    </div>
 
    <a href="<%= root_path %>" class="app-sidebar-brand" style="text-decoration: none; color: inherit; transition: opacity 0.2s;" onmouseover="this.style.opacity=0.8" onmouseout="this.style.opacity=1">
      <span class="brand-dot"></span>
      <div>
        <% if current_webapp_domain.present? %>
          <h2><%= current_webapp_domain.title.presence || current_webapp_domain.brand_port.name %></h2>
        <% else %>
          <h2>Flowpulse</h2>
        <% end %>
      </div>
    </a>
    <% if content_for?(:sidebar_extra) %>
      <div style="margin-top: 1rem; padding-top: 1rem; border-top: 1px solid rgba(148, 163, 184, 0.25);">
        <%= yield :sidebar_extra %>
      </div>
    <% end %>

    <nav class="app-sidebar-nav" style="flex: 0 0 auto; padding-top: 0; margin-bottom: 1rem;">
      <div class="sidebar-group">
        <%= link_to "Hub Operativo", hub_dashboard_path, class: current_page?(hub_dashboard_path) ? "active" : nil, data: { action: "click->sidebar#close" } %>
      </div>
    </nav>
    

    <div class="workspace-switcher">
      <p class="sidebar-group-label">Spazio attivo</p>
      <%= form_with url: workspace_dashboard_path, method: :patch, class: "workspace-switcher-form" do |form| %>
        <%= form.select :mode,
                        options_for_select(available_workspace_modes.map { |workspace| [workspace[:label], workspace[:key]] }, current_workspace_mode),
                        {},
                        class: "workspace-switcher-select",
                        onchange: "this.form.requestSubmit()" %>
      <% end %>
      <% unless Rails.env.development? %>
        <p class="sidebar-group-label" style="margin-top: 0.65rem; line-height: 1.4; text-transform: none; letter-spacing: 0; color: rgba(15, 23, 42, 0.7);">
          <% if webapp_domain_context? && current_webapp_domain.present? %>
            Stai lavorando nella web app <strong><%= current_webapp_domain.title.presence || current_webapp_domain.brand_port.name %></strong>.
          <% else %>
            Stai lavorando nell'hub <strong>Flowpulse</strong>.
          <% end %>
        </p>
      <% end %>
      <% if Rails.env.production? && current_workspace_mode == "creator" && creator_world_switch_options.present? %>
        <div style="margin-top: 0.8rem;">
          <p class="sidebar-group-label" style="margin-bottom: 0.35rem;">Mondo</p>
          <select class="workspace-switcher-select" onchange="if(this.value){ window.location = this.value }">
            <% creator_world_switch_options.each do |label, target| %>
              <option value="<%= target %>" <%= "selected" if target == creator_world_switch_current_target %>><%= label %></option>
            <% end %>
          </select>
        </div>
      <% end %>
    </div>

    <nav class="app-sidebar-nav">

      <% if current_workspace_mode == "traveler" && webapp_domain_context? %>
        <div class="sidebar-group sidebar-group-traveler">
          <a href="/flowpulse_v_4/4_1impegno.html" data-action="click->sidebar#close">Le mie mappe percorse</a>
          <a href="/flowpulse_v_4/6_calendar_journey.html" data-action="click->sidebar#close">Viaggi vissuti</a>
          <a href="/flowpulse_v_4/5_calendario_ticket.html" data-action="click->sidebar#close">Ticket e calendario</a>
        </div>
      <% end %>

      <% if current_workspace_mode == "creator" && Current.session.user.profile&.creator? %>
        <div class="sidebar-group sidebar-group-creator">
          <%= link_to "Carta nautica", current_creator_carta_nautica_path, class: current_page?(current_creator_carta_nautica_path) ? "active" : nil, data: { action: "click->sidebar#close" } %>
          <%= link_to "Albero dei brand", current_creator_brand_tree_path, class: current_page?(creator_brand_tree_path) ? "active" : nil, data: { action: "click->sidebar#close" } %>
          <a href="/flowpulse_v_4/mappa_metro.html" data-action="click->sidebar#close">Mappa metro</a>
          <a href="/flowpulse_v_4/3_rails4b.html" data-action="click->sidebar#close">Trail creator</a>
          <%= link_to "Valore percorsi", creator_value_architecture_path, class: current_page?(creator_value_architecture_path) ? "active" : nil, data: { action: "click->sidebar#close" } %>
        </div>
      <% end %>

      <% if current_workspace_mode == "professional" && webapp_domain_context? %>
        <div class="sidebar-group sidebar-group-professionals">
          <%= link_to "Crea un percorso", professionals_path, class: current_page?(professionals_path) ? "active" : nil, data: { action: "click->sidebar#close" } %>
          <%= link_to "Listino servizi", professionals_catalog_path, class: current_page?(professionals_catalog_path) ? "active" : nil, data: { action: "click->sidebar#close" } %>
          <%= link_to "Valore", professionals_value_path, class: current_page?(professionals_value_path) ? "active" : nil, data: { action: "click->sidebar#close" } %>
          <%= link_to "Formazione", professionals_titles_path, class: current_page?(professionals_titles_path) ? "active" : nil, data: { action: "click->sidebar#close" } %>
        </div>
      <% end %>

      <% if current_workspace_mode == "superadmin" && Current.session.user.superadmin? %>
        <div class="sidebar-group sidebar-group-superadmin">
          <%= link_to "Richieste accessi", admin_creator_requests_path, class: current_page?(admin_creator_requests_path) ? "active" : nil, data: { action: "click->sidebar#close" } %>
          <%= link_to "Formati", admin_formats_path, class: current_page?(admin_formats_path) ? "active" : nil, data: { action: "click->sidebar#close" } %>
          <%= link_to "Persone", admin_users_path, class: current_page?(admin_users_path) || current_page?(admin_profiles_path) ? "active" : nil, data: { action: "click->sidebar#close" } %>
        </div>
      <% end %>

    </nav>

   

    <% if development_domain_simulation_active? %>
      <div style="margin-top: auto; padding-top: 1rem; border-top: 1px solid rgba(148, 163, 184, 0.25);">
        <p class="sidebar-group-label" style="margin-bottom: 0.45rem;">Dev domain</p>
        <%= form_with url: request.path, method: :get, local: true do |form| %>
          <% development_domain_switch_query_params.each do |key, value| %>
            <% Array.wrap(value).each do |item| %>
              <%= hidden_field_tag "#{key}[]", item if value.is_a?(Array) %>
              <%= hidden_field_tag key, item unless value.is_a?(Array) %>
            <% end %>
          <% end %>
          <%= form.select :_domain,
                          options_for_select(development_domain_switch_options, development_domain_switch_host),
                          {},
                          class: "workspace-switcher-select",
                          style: "font-size: 0.8rem; min-height: 2.2rem;",
                          onchange: "this.form.requestSubmit()" %>
        <% end %>
      </div>
    <% end %>
  </aside>
</div>
