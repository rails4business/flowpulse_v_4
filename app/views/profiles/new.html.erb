<% content_for :title, "Completa il profilo" %>

<section class="auth-shell">
  <div class="auth-grid">
    <div class="auth-copy">
      <p class="eyebrow">Profilo</p>
      <h1>Completa il tuo profilo.</h1>
      <p>
        Secondo step: completa le prime informazioni visibili del profilo.
        Di base entrerai come viaggiatore. La possibilita' di creare mappe e branch verra' abilitata separatamente.
      </p>
    </div>

    <div class="auth-card">
      <% if @profile.errors.any? %>
        <div class="flash-card flash-alert">
          <strong>Profilo non completato.</strong>
          <p><%= @profile.errors.full_messages.to_sentence %></p>
        </div>
      <% end %>

      <%= form_with model: @profile, url: profile_path, class: "auth-form" do |form| %>
        <div>
          <%= form.label :display_name, "Nome profilo" %>
          <%= form.text_field :display_name, required: true, class: "text-input" %>
        </div>

        <div>
          <%= form.label :bio, "Bio iniziale" %>
          <%= form.text_area :bio, rows: 4, class: "text-area" %>
        </div>

        <div>
          <%= form.label :visibility, "Visibilita'" %>
          <%= form.select :visibility, [["Privato", "private"], ["Pubblico", "public"]], {}, class: "text-input" %>
        </div>

        <%= form.submit "Completa profilo", class: "btn btn-primary auth-submit" %>
      <% end %>

      <p class="auth-note">
        Di base entrerai come viaggiatore. L'accesso creator si richiede dopo dal profilo.
      </p>
    </div>
  </div>
</section>
