<% content_for :title, "Nuovo contenuto per #{@port.name}" %>

<section class="dashboard-shell bg-slate-50 min-h-screen">
  <div class="flex h-full w-full mx-auto" style="max-width: 1600px;">
    <%= render "shared/app_sidebar" %>

    <div class="flex-1 px-4 md:px-8 py-10 lg:px-12 w-full max-w-5xl overflow-y-auto">
      <div class="mb-8 pl-2">
         <%= link_to creator_port_path(@port), class: "inline-flex items-center gap-2 text-slate-500 hover:text-indigo-600 font-bold text-sm mb-4 transition-colors group" do %>
            <span class="material-symbols-outlined text-[18px] group-hover:-translate-x-1 transition-transform">arrow_back</span> Torna a <%= @port.name %>
         <% end %>
         <p class="text-indigo-600 text-[0.7rem] font-black uppercase tracking-widest mb-1.5 flex items-center gap-1.5">
           <span class="w-1.5 h-1.5 rounded-full bg-indigo-500"></span> Editor Contenuti
         </p>
         <h1 class="text-3xl md:text-5xl font-extrabold text-slate-900 tracking-tight m-0">Inizializza Contenuto</h1>
         <p class="text-slate-500 font-medium mt-3 text-lg leading-relaxed">Stai creando il profilo contenutistico master per il portale <strong class="text-slate-800 px-2 py-0.5 rounded-md bg-white border border-slate-200"><%= @port.name %></strong>.</p>
      </div>

      <%= render "form", port: @port, content: @content %>
    </div>
  </div>
</section>
