<% content_for :title, "Mappa terra di #{@port.name}" %>
<% station_kind_options = Station.station_kinds.keys.map { |key| [Station.new(station_kind: key).station_kind_label, key] } %>
<% shared_group_angle_options = Station.shared_group_angles.keys.map { |key| [key.humanize, key] } %>
<% line_kind_options = Line.line_kinds.keys.map { |key| [key.humanize, key] } %>
<% default_line_kind = params.dig(:line, :line_kind).presence || Line.line_kinds.keys.first %>
<% default_station_kind = params.dig(:station, :station_kind).presence || "normal" %>
<% default_station_relative_position = params.dig(:station, :relative_position).presence_in(%w[before after]) || "after" %>
<% experience_kind_options = Experience.experience_kinds.keys.map { |key| [key.humanize, key] } %>
<% experience_picker_options = @experiences.map { |experience| { id: experience.id, name: experience.name } }.to_json %>
<% port_picker_options = @linkable_ports.to_a.map { |port| { id: port.id, name: port.name } }.to_json %>
<% default_existing_experience_id = params.dig(:station, :experience_id).presence || @selected_station&.canonical_experience&.id %>
<% default_existing_experience_name = @experiences.find { |experience| experience.id == default_existing_experience_id.to_i }&.name %>
<% default_existing_port_id = params.dig(:station, :link_port_id).presence || @selected_station&.link_port_id %>
<% default_existing_port_name = @linkable_ports.to_a.find { |port| port.id == default_existing_port_id.to_i }&.name %>
<% station_picker_options = @lines.flat_map { |line|
  ordered_stations = line.stations.sort_by { |station| [station.position, station.created_at] }
  ordered_stations.map.with_index do |station, index|
    position = @rendered_station_positions&.[](station.id)
    next if position.blank?

    previous_station = index.positive? ? ordered_stations[index - 1] : nil
    previous_position = previous_station.present? ? @rendered_station_positions&.[](previous_station.id) : nil
    next_station = ordered_stations[index + 1]
    next_position = next_station.present? ? @rendered_station_positions&.[](next_station.id) : nil

    {
      id: station.id,
      primaryStationId: station.primary_station.id,
      lineId: station.line_id,
      x: position[:x],
      y: position[:y],
      name: station.primary_station.name,
      first: previous_station.blank?,
      terminal: next_station.blank?,
      prevX: previous_position&.dig(:x),
      prevY: previous_position&.dig(:y),
      nextX: next_position&.dig(:x),
      nextY: next_position&.dig(:y)
    }
  end
}.flatten.compact.to_json %>
<% land_map_params = { edit: (@edit_mode ? 1 : nil), move: (@move_mode ? 1 : nil), line_id: @selected_line&.id } %>
<% preview_origin_station =
  if @active_panel == "new_line"
    @selected_station&.primary_station
  else
    @selected_station || @selected_line&.stations&.last
  end %>
<% preview_origin = preview_origin_station.present? ? @rendered_station_positions&.[](preview_origin_station.id) : nil %>
<% context_line = @selected_line || @selected_station&.line %>
<% selected_line_row = @line_map_rows&.find { |row| row[:line] == @selected_line } %>
<% context_anchor =
  if @selected_station.present?
    @rendered_station_positions&.[](@selected_station.id)
  elsif @selected_line.present?
    first_station = @selected_line.stations.first
    @rendered_station_positions&.[](first_station&.id) || (selected_line_row.present? ? { x: 140, y: selected_line_row[:y] } : nil)
  end %>
<% context_menu_width = 340 %>
<% context_menu_left =
  if context_anchor.present? && @map_width.present?
    [[context_anchor[:x] - (context_menu_width / 2), 24].max, @map_width - context_menu_width - 24].min
  else
    24
  end %>
<% context_menu_top = context_anchor.present? ? (context_anchor[:y] + 34) : 24 %>
<% selected_station_group = @selected_station.present? ? @shared_station_group_map[@selected_station.id] : nil %>
<% if @selected_line.present? %>
  <% selected_line_color = @line_map_rows.find { |row| row[:line] == @selected_line }&.dig(:color) || "#6366f1" %>
  <% content_for :sidebar_extra do %>
    <div class="rounded-[1.25rem] border border-slate-200 bg-white p-4 shadow-sm">
      <div class="text-[11px] font-black uppercase tracking-wider text-slate-400">Line attiva</div>
      <div class="mt-3 flex items-start gap-3">
        <span class="mt-1 inline-block h-3.5 w-3.5 rounded-full" style="background: <%= selected_line_color %>;"></span>
        <div class="min-w-0">
          <div class="truncate text-sm font-black text-slate-900"><%= @selected_line.name %></div>
          <div class="mt-1 text-[11px] font-bold uppercase tracking-wider" style="color: <%= selected_line_color %>;"><%= @selected_line.line_kind_label %></div>
          <% if @selected_line.content&.description.present? %>
            <p class="mt-3 text-xs leading-relaxed text-slate-500"><%= truncate(@selected_line.content.description, length: 120) %></p>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
<% end %>

<section class="dashboard-shell bg-slate-50 min-h-screen">
  <div class="flex h-full w-full mx-auto" style="max-width: 1700px;">
    <%= render "shared/app_sidebar" %>

    <div class="flex-1 px-4 md:px-8 py-6 lg:py-8 lg:px-12 overflow-y-auto" data-controller="land-map-builder" data-land-map-builder-mode-value="<%= @active_panel %>" data-land-map-builder-move-mode-value="<%= @move_mode %>" data-land-map-builder-clear-selection-path-value="<%= land_map_creator_port_path(@port, edit: 1, move: (@move_mode ? 1 : nil)) %>" data-land-map-builder-stations-value="<%= station_picker_options %>" data-land-map-builder-selected-line-id-value="<%= @selected_line&.id || 0 %>">
      <div class="mb-6 flex items-center gap-4">
        <div class="inline-flex items-center gap-2 rounded-full border border-slate-200 bg-white px-2 py-2 shadow-sm">
          <%= link_to creator_port_path(@port), class: "inline-flex h-10 w-10 items-center justify-center rounded-full text-slate-700 hover:bg-slate-50 transition-colors", title: "Torna al port", aria: { label: "Torna al port" } do %>
            <span class="material-symbols-outlined text-[18px]">arrow_back</span>
          <% end %>
          <% if @edit_mode %>
            <%= link_to land_map_creator_port_path(@port, edit: 1, panel: "new_line", line_id: @selected_line&.id, station_id: @selected_station&.id), class: "inline-flex h-10 w-10 items-center justify-center rounded-full bg-slate-900 text-white hover:bg-slate-800 transition-colors", title: "Nuova line", aria: { label: "Nuova line" } do %>
              <span class="material-symbols-outlined text-[18px]">add_road</span>
            <% end %>
            <%= link_to land_map_creator_port_path(@port, edit: 1, move: (@move_mode ? nil : 1), line_id: @selected_line&.id, station_id: @selected_station&.id), class: "inline-flex h-10 w-10 items-center justify-center rounded-full border transition-colors #{ @move_mode ? 'border-slate-900 bg-slate-900 text-white hover:bg-slate-800' : 'border-slate-200 bg-white text-slate-700 hover:bg-slate-50' }", title: "Sposta station", aria: { label: "Sposta station" } do %>
              <span class="material-symbols-outlined text-[18px]">open_with</span>
            <% end %>
            <%= link_to land_map_creator_port_path(@port), class: "inline-flex h-10 w-10 items-center justify-center rounded-full text-slate-700 hover:bg-slate-50 transition-colors", title: "Annulla", aria: { label: "Annulla" } do %>
              <span class="material-symbols-outlined text-[18px]">close</span>
            <% end %>
          <% else %>
            <%= link_to land_map_creator_port_path(@port, edit: 1, line_id: @selected_line&.id), class: "inline-flex h-10 w-10 items-center justify-center rounded-full bg-slate-900 text-white hover:bg-slate-800 transition-colors", title: "Modifica", aria: { label: "Modifica" } do %>
              <span class="material-symbols-outlined text-[18px]">edit</span>
            <% end %>
          <% end %>
        </div>

        <h1 class="page-title text-2xl md:text-3xl font-black text-slate-900 m-0">Mappa terra di <%= @port.name %></h1>
      </div>

      <% if @edit_mode && @active_panel.in?(%w[new_line new_station]) %>
        <div class="mb-4 rounded-[1.25rem] border border-indigo-200 bg-indigo-50 px-5 py-4">
          <div class="flex items-start justify-between gap-4">
            <div>
              <p class="mt-1 text-sm font-bold text-slate-800">
                <% if @active_panel == "new_line" %>
                  Muovi il cursore sulla mappa: se passi vicino a una station, la nuova line partira' da quel nodo; altrimenti nascera' da un punto libero.
                <% else %>
                  Muovi il cursore sulla mappa: se passi vicino a una station della line, la nuova station partira' da quel nodo; altrimenti si posizionera' su un punto libero.
                <% end %>
              </p>
              <p class="mt-2 text-xs font-bold <%= @active_panel == "new_line" ? "text-indigo-600" : "text-emerald-600" %>">
                <span data-land-map-builder-target="<%= @active_panel == "new_line" ? "lineHint" : "stationHint" %>">
                  <%= @active_panel == "new_line" ? "In attesa del primo click sulla mappa." : "In attesa del click sulla mappa." %>
                </span>
              </p>
            </div>
            <%= link_to "Annulla", land_map_creator_port_path(@port, edit: 1, line_id: @selected_line&.id), class: "inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white text-slate-700 font-bold border border-slate-200 hover:bg-slate-50 text-xs" %>
          </div>
        </div>
      <% end %>

      <div class="relative bg-white rounded-[2rem] p-2 shadow-lg shadow-slate-200/40 border border-slate-200 mb-8 overflow-hidden">
        <div class="overflow-auto rounded-[1.5rem]" style="background: radial-gradient(circle, #f8fafc 10%, #e2e8f0 100%);">
          <div class="relative inline-block min-w-full">
            <% if @edit_mode && @active_panel.blank? && !@move_mode %>
              <% if @selected_line.present? || @selected_station.present? %>
                <div class="absolute z-10" style="left: <%= context_menu_left %>px; top: <%= context_menu_top %>px;">
                  <div class="flex w-[220px] flex-col gap-1.5 bg-white/96 p-1 shadow-lg backdrop-blur-sm" data-land-map-builder-target="contextMenu">
                    <div class="px-2 py-1 text-[11px] font-black uppercase tracking-wider text-slate-400">
                      <% if @selected_station.present? %>
                        Station selezionata
                      <% else %>
                        Line selezionata
                      <% end %>
                    </div>
                    <% if @selected_line.present? %>
                      <% selected_line_color = @line_map_rows.find { |row| row[:line] == @selected_line }&.dig(:color) || "#6366f1" %>
                      <div class="flex items-center gap-2 px-2 py-1 text-xs font-bold text-slate-700">
                        <span class="inline-block h-2.5 w-2.5 rounded-full" style="background: <%= selected_line_color %>;"></span>
                        <span class="truncate"><%= @selected_line.name %></span>
                      </div>
                    <% end %>
                    <% if @selected_station.present? %>
                      <div class="flex items-center gap-2 px-2 py-1 text-xs font-bold text-sky-700">
                        <span class="inline-flex h-4 min-w-4 items-center justify-center rounded-full bg-sky-100 px-1 text-[9px] font-black text-sky-700">
                          <%= @selected_station.opening? ? "IN" : (@selected_station.closing? ? "OUT" : "•") %>
                        </span>
                        <span class="truncate"><%= @selected_station.name %></span>
                      </div>
                    <% end %>
                    <% if @selected_station.present? %>
                      <%= link_to safe_join([content_tag(:span, "north", class: "material-symbols-outlined text-[16px]"), " Nuova station prima"]), land_map_creator_port_path(@port, edit: 1, panel: "new_station", line_id: context_line.id, station_id: @selected_station&.id, station: { relative_position: "before" }), class: "inline-flex items-center gap-2 px-3 py-2 text-xs font-black text-slate-800 hover:bg-slate-100 transition-colors" %>
                      <%= link_to safe_join([content_tag(:span, "south", class: "material-symbols-outlined text-[16px]"), " Nuova station dopo"]), land_map_creator_port_path(@port, edit: 1, panel: "new_station", line_id: context_line.id, station_id: @selected_station&.id, station: { relative_position: "after" }), class: "inline-flex items-center gap-2 px-3 py-2 text-xs font-black text-slate-800 hover:bg-slate-100 transition-colors" %>
                    <% elsif context_line.present? %>
                      <%= link_to safe_join([content_tag(:span, "south", class: "material-symbols-outlined text-[16px]"), " Nuova station finale"]), land_map_creator_port_path(@port, edit: 1, panel: "new_station", line_id: context_line.id, station: { relative_position: "after" }), class: "inline-flex items-center gap-2 px-3 py-2 text-xs font-black text-slate-800 hover:bg-slate-100 transition-colors" %>
                    <% end %>
                    <%= link_to safe_join([content_tag(:span, "add_road", class: "material-symbols-outlined text-[16px]"), " Aggiungi line"]), land_map_creator_port_path(@port, edit: 1, panel: "new_line", line_id: context_line&.id, station_id: @selected_station&.id), class: "inline-flex items-center gap-2 px-3 py-2 text-xs font-black text-slate-800 hover:bg-slate-100 transition-colors" %>
                    <% if @selected_line.present? %>
                      <%= link_to safe_join([content_tag(:span, "edit", class: "material-symbols-outlined text-[16px]"), " Modifica line"]), land_map_creator_port_path(@port, edit: 1, panel: "edit_line", line_id: @selected_line.id, station_id: @selected_station&.id), class: "inline-flex items-center gap-2 px-3 py-2 text-xs font-black text-slate-800 hover:bg-slate-100 transition-colors" %>
                    <% end %>
                    <% if @selected_station.present? %>
                      <%= link_to safe_join([content_tag(:span, "edit", class: "material-symbols-outlined text-[16px]"), " Modifica station"]), land_map_creator_port_path(@port, edit: 1, panel: "edit_station", line_id: @selected_line.id, station_id: @selected_station.id), class: "inline-flex items-center gap-2 px-3 py-2 text-xs font-black text-slate-800 hover:bg-slate-100 transition-colors" %>
                      <% if @selected_station.connector? %>
                        <div class="mt-1 border-t border-slate-100 pt-1">
                          <div class="px-3 py-1 text-[10px] font-black uppercase tracking-wider text-slate-400">Nodo condiviso</div>
                          <div class="grid grid-cols-2 gap-1 px-1 pb-1">
                            <%= button_to creator_port_line_station_path(@port, @selected_line, @selected_station), method: :patch, params: { return_to: "land_map", station: { link_order: @selected_station.link_order.to_i - 1 } }, class: "inline-flex w-full items-center justify-center gap-1 px-2 py-2 text-[11px] font-black text-slate-700 hover:bg-slate-100 transition-colors" do %>
                              <span class="material-symbols-outlined text-[14px]">west</span>
                              Dietro
                            <% end %>
                            <%= button_to creator_port_line_station_path(@port, @selected_line, @selected_station), method: :patch, params: { return_to: "land_map", station: { link_order: @selected_station.link_order.to_i + 1 } }, class: "inline-flex w-full items-center justify-center gap-1 px-2 py-2 text-[11px] font-black text-slate-700 hover:bg-slate-100 transition-colors" do %>
                              <span class="material-symbols-outlined text-[14px]">east</span>
                              Avanti
                            <% end %>
                          </div>
                        </div>
                      <% end %>
                      <% if selected_station_group.present? %>
                        <div class="grid grid-cols-2 gap-1 px-1 pb-1">
                          <%= button_to creator_port_line_station_path(@port, @selected_line, @selected_station), method: :patch, params: { return_to: "land_map", station: { shared_group_angle: "horizontal" } }, class: "inline-flex w-full items-center justify-center gap-1 px-2 py-2 text-[11px] font-black #{ @selected_station.primary_station.shared_group_angle == 'horizontal' ? 'bg-slate-900 text-white' : 'text-slate-700 hover:bg-slate-100' } transition-colors" do %>
                            <span class="material-symbols-outlined text-[14px]">switch_left</span>
                            Orizzontale
                          <% end %>
                          <%= button_to creator_port_line_station_path(@port, @selected_line, @selected_station), method: :patch, params: { return_to: "land_map", station: { shared_group_angle: "vertical" } }, class: "inline-flex w-full items-center justify-center gap-1 px-2 py-2 text-[11px] font-black #{ @selected_station.primary_station.shared_group_angle == 'vertical' ? 'bg-slate-900 text-white' : 'text-slate-700 hover:bg-slate-100' } transition-colors" do %>
                            <span class="material-symbols-outlined text-[14px]">switch_right</span>
                            Verticale
                          <% end %>
                          <%= button_to creator_port_line_station_path(@port, @selected_line, @selected_station), method: :patch, params: { return_to: "land_map", station: { shared_group_angle: "diagonal_up" } }, class: "inline-flex w-full items-center justify-center gap-1 px-2 py-2 text-[11px] font-black #{ @selected_station.primary_station.shared_group_angle == 'diagonal_up' ? 'bg-slate-900 text-white' : 'text-slate-700 hover:bg-slate-100' } transition-colors" do %>
                            <span class="material-symbols-outlined text-[14px]">north_east</span>
                            Diag su
                          <% end %>
                          <%= button_to creator_port_line_station_path(@port, @selected_line, @selected_station), method: :patch, params: { return_to: "land_map", station: { shared_group_angle: "diagonal_down" } }, class: "inline-flex w-full items-center justify-center gap-1 px-2 py-2 text-[11px] font-black #{ @selected_station.primary_station.shared_group_angle == 'diagonal_down' ? 'bg-slate-900 text-white' : 'text-slate-700 hover:bg-slate-100' } transition-colors" do %>
                            <span class="material-symbols-outlined text-[14px]">south_east</span>
                            Diag giu
                          <% end %>
                        </div>
                      <% end %>
                      <%= button_to creator_port_line_station_path(@port, @selected_line, @selected_station), method: :delete, form: { data: { turbo_confirm: "Eliminare questa station?" } }, class: "inline-flex w-full items-center gap-2 px-3 py-2 text-xs font-black text-rose-700 hover:bg-rose-50 transition-colors text-left" do %>
                        <span class="material-symbols-outlined text-[16px]">delete</span>
                        Elimina station
                      <% end %>
                    <% end %>
                    <%= link_to safe_join([content_tag(:span, "close", class: "material-symbols-outlined text-[16px]"), " Annulla"]), land_map_creator_port_path(@port, edit: 1), class: "inline-flex items-center gap-2 px-3 py-2 text-xs font-black text-slate-500 hover:bg-slate-100 transition-colors" %>
                  </div>
                </div>
              <% end %>
            <% end %>
          <% if @line_map_rows.any? %>
            <svg viewBox="0 0 <%= @map_width %> <%= @map_height %>" style="width: 100%; min-width: 960px; height: auto; display: block;" data-land-map-builder-target="svg" data-action="click->land-map-builder#backgroundClick">
              <defs>
                <pattern id="land-grid" width="60" height="60" patternUnits="userSpaceOnUse">
                  <path d="M 60 0 L 0 0 0 60" fill="none" stroke="rgba(255,255,255,0.6)" stroke-width="2" />
                  <circle cx="0" cy="0" r="1.5" fill="#cbd5e1" />
                </pattern>
                <filter id="shadow" x="-20%" y="-20%" width="140%" height="140%">
                  <feDropShadow dx="0" dy="4" stdDeviation="6" flood-opacity="0.1" />
                </filter>
              </defs>
              <rect width="100%" height="100%" fill="url(#land-grid)" />

              <% @line_map_rows.each do |row| %>
                <% points = row[:line].stations.map { |station| "#{@rendered_station_positions.fetch(station.id)[:x]},#{@rendered_station_positions.fetch(station.id)[:y]}" }.join(" ") %>
                <% selected = @selected_line == row[:line] %>
                <a xlink:href="<%= land_map_creator_port_path(@port, edit: (@edit_mode ? 1 : nil), move: (@move_mode ? 1 : nil), line_id: row[:line].id) %>" class="group cursor-pointer">
                  <% if row[:line].stations.any? %>
                    <polyline points="<%= points %>" fill="none" stroke="<%= row[:color] %>" stroke-width="<%= selected ? 8 : 10 %>" stroke-linecap="round" stroke-linejoin="round" filter="url(#shadow)" opacity="<%= selected ? 1 : 0.88 %>" data-line-station-ids="<%= row[:line].stations.map(&:id).join(',') %>" />
                  <% end %>
                </a>
              <% end %>

              <% @link_segments.each do |segment| %>
                <line
                  x1="<%= segment[:from][:x] %>"
                  y1="<%= segment[:from][:y] %>"
                  x2="<%= segment[:to][:x] %>"
                  y2="<%= segment[:to][:y] %>"
                  stroke="#111827"
                  stroke-width="<%= segment[:selected] ? 7 : 5 %>"
                  opacity="1"
                  stroke-linecap="round"
                  data-link-from-id="<%= segment[:station].id %>"
                  data-link-to-id="<%= segment[:station].link_station_id %>"
                />
              <% end %>

              <% @shared_station_groups.each do |group| %>
                <% bounds = group[:bounds] %>
                <% sorted_members =
                  group[:render_members].sort_by { |member| member[:order_index].to_i } %>
                <% shared_points = sorted_members.map { |member| "#{member[:x]},#{member[:y]}" }.join(" ") %>
                <% if sorted_members.size > 1 %>
                  <polyline
                    points="<%= shared_points %>"
                    fill="none"
                    stroke="#111827"
                    stroke-width="<%= group[:selected] ? 7 : 5 %>"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    opacity="1"
                    data-shared-group-station-ids="<%= sorted_members.map { |member| member[:station].id }.join(',') %>"
                  />
                  <polyline
                    points="<%= shared_points %>"
                    fill="none"
                    stroke="white"
                    stroke-width="<%= group[:selected] ? 3.5 : 2.5 %>"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    opacity="1"
                    data-shared-group-station-ids="<%= sorted_members.map { |member| member[:station].id }.join(',') %>"
                  />
                <% end %>
                <% group[:render_members].each do |member| %>
                  <% member_station = member[:station] %>
                  <% point_x = member[:x] %>
                  <% point_y = member[:y] %>
                  <% member_selected = @selected_station == member_station %>
                  <% primary_member = member_station == group[:primary_station] %>
                  <% port_shape_member = primary_member && (member_station.port_entry? || member_station.link_port.present?) %>
                  <a xlink:href="<%= land_map_creator_port_path(@port, edit: (@edit_mode ? 1 : nil), move: (@move_mode ? 1 : nil), line_id: member_station.line_id, station_id: member_station.id) %>" class="group cursor-pointer" style="outline: none;" data-action="mousedown->land-map-builder#stationMouseDown" data-station-id="<%= member_station.id %>" data-primary-station-id="<%= member_station.primary_station.id %>" data-station-x="<%= point_x %>" data-station-y="<%= point_y %>" data-reposition-path="<%= creator_port_line_reposition_station_path(@port, member_station.line, member_station) %>">
                    <% if member_selected %>
                      <circle cx="<%= point_x %>" cy="<%= point_y %>" r="11" fill="rgba(99,102,241,0.12)" stroke="rgba(99,102,241,0.28)" stroke-width="2.5" />
                    <% end %>
                    <% if port_shape_member %>
                      <% diamond_size = member_selected ? 10.5 : 9 %>
                      <polygon
                        points="<%= [ [point_x, point_y - diamond_size], [point_x + diamond_size, point_y], [point_x, point_y + diamond_size], [point_x - diamond_size, point_y] ].map { |px, py| "#{px},#{py}" }.join(' ') %>"
                        fill="white"
                        stroke="#111827"
                        stroke-width="<%= member_selected ? 3.2 : 2.7 %>"
                        filter="url(#shadow)"
                      />
                      <% if member_station.port_entry? %>
                        <polygon
                          points="<%= [ [point_x, point_y - diamond_size], [point_x + diamond_size, point_y], [point_x - diamond_size, point_y] ].map { |px, py| "#{px},#{py}" }.join(' ') %>"
                          fill="#111827"
                        />
                        <line x1="<%= point_x - diamond_size * 0.64 %>" y1="<%= point_y %>" x2="<%= point_x + diamond_size * 0.64 %>" y2="<%= point_y %>" stroke="#111827" stroke-width="1.8" stroke-linecap="round" />
                      <% else %>
                        <polygon
                          points="<%= [ [point_x, point_y + diamond_size], [point_x + diamond_size, point_y], [point_x - diamond_size, point_y] ].map { |px, py| "#{px},#{py}" }.join(' ') %>"
                          fill="#111827"
                        />
                        <line x1="<%= point_x - diamond_size * 0.64 %>" y1="<%= point_y %>" x2="<%= point_x + diamond_size * 0.64 %>" y2="<%= point_y %>" stroke="#111827" stroke-width="1.8" stroke-linecap="round" />
                      <% end %>
                    <% else %>
                      <circle
                        cx="<%= point_x %>"
                        cy="<%= point_y %>"
                        r="<%= member_selected ? 8.5 : 7 %>"
                        fill="white"
                        stroke="#111827"
                        stroke-width="<%= member_selected ? 3.2 : 2.7 %>"
                        filter="url(#shadow)"
                      />
                    <% end %>
                    <% if primary_member && !port_shape_member %>
                      <circle
                        cx="<%= point_x %>"
                        cy="<%= point_y %>"
                        r="<%= member_selected ? 3.2 : 2.6 %>"
                        fill="#111827"
                      />
                    <% end %>
                  </a>
                <% end %>
                <% primary_member = group[:render_members].find { |member| member[:station] == group[:primary_station] } %>
                <% primary_point = primary_member.present? ? { x: primary_member[:x], y: primary_member[:y] } : nil %>
                <% if primary_point.present? %>
                  <g data-shared-group-labels="<%= group[:primary_station].id %>" data-label-origin-x="<%= primary_point[:x] %>" data-label-origin-y="<%= primary_point[:y] %>">
                    <text x="<%= primary_point[:x] %>" y="<%= bounds[:y] + bounds[:height] + 16 %>" text-anchor="middle" font-size="13" font-weight="800" fill="#1e293b"><%= group[:primary_station].name %></text>
                    <text x="<%= primary_point[:x] %>" y="<%= bounds[:y] + bounds[:height] + 30 %>" text-anchor="middle" font-size="11" font-weight="600" fill="#64748b"><%= group[:primary_station].canonical_experience&.name %></text>
                  </g>
                <% end %>
              <% end %>

              <% if @edit_mode && @active_panel.in?(%w[new_line new_station]) && preview_origin.present? %>
                <line
                  x1="<%= preview_origin[:x] %>"
                  y1="<%= preview_origin[:y] %>"
                  x2="<%= preview_origin[:x] %>"
                  y2="<%= preview_origin[:y] %>"
                  stroke="#0f172a"
                  stroke-width="5"
                  stroke-dasharray="10 8"
                  stroke-linecap="round"
                  opacity="0.55"
                  class="hidden pointer-events-none"
                  data-land-map-builder-target="previewLine"
                  data-origin-x="<%= preview_origin[:x] %>"
                  data-origin-y="<%= preview_origin[:y] %>"
                />
              <% end %>

              <% @line_map_rows.each do |row| %>
                <% row[:line].stations.each do |station| %>
                  <% x = @rendered_station_positions.fetch(station.id)[:x] %>
                  <% y = @rendered_station_positions.fetch(station.id)[:y] %>
                  <% selected_station = @selected_station == station %>
                  <% shared_group = @shared_station_group_map[station.id] %>
                  <% in_shared_group = shared_group.present? %>
                  <% outer_fill =
                    if station.opening?
                      "#dcfce7"
                    elsif station.closing?
                      "#fee2e2"
                    elsif station.branch?
                      "#fef3c7"
                    elsif station.gate?
                      "#e0f2fe"
                    else
                      "white"
                    end %>
                  <% marker_label =
                    if station.branch?
                      "BR"
                    elsif station.gate?
                      "GT"
                    end %>
                  <% marker_color =
                    if station.branch?
                      "#b45309"
                    elsif station.gate?
                      "#0369a1"
                    else
                      "#0f172a"
                    end %>
                  <% port_shape_station = (station.port_entry? || station.link_port.present?) && !station.branch? && !station.gate? && !station.connector? && !in_shared_group %>
                  <a xlink:href="<%= land_map_creator_port_path(@port, edit: (@edit_mode ? 1 : nil), move: (@move_mode ? 1 : nil), line_id: row[:line].id, station_id: station.id) %>" class="group cursor-pointer" style="outline: none;" data-action="mousedown->land-map-builder#stationMouseDown" data-station-id="<%= station.id %>" data-primary-station-id="<%= station.primary_station.id %>" data-station-x="<%= x %>" data-station-y="<%= y %>" data-reposition-path="<%= creator_port_line_reposition_station_path(@port, row[:line], station) %>">
                    <% if selected_station && !in_shared_group %>
                      <circle cx="<%= x %>" cy="<%= y %>" r="18" fill="rgba(99,102,241,0.12)" stroke="rgba(99,102,241,0.28)" stroke-width="3" />
                    <% end %>
                    <% if in_shared_group %>
                    <% elsif station.connector? %>
                      <% connector_width = selected_station ? 34 : 30 %>
                      <% connector_height = selected_station ? 16 : 14 %>
                      <rect
                        x="<%= x - (connector_width / 2.0) %>"
                        y="<%= y - (connector_height / 2.0) %>"
                        width="<%= connector_width %>"
                        height="<%= connector_height %>"
                        rx="<%= connector_height / 2.0 %>"
                        fill="white"
                        stroke="<%= row[:color] %>"
                        stroke-width="<%= selected_station ? 4 : 3 %>"
                        filter="url(#shadow)"
                      />
                      <rect
                        x="<%= x - (connector_width / 2.0) + 4 %>"
                        y="<%= y - (connector_height / 2.0) + 4 %>"
                        width="<%= connector_width - 8 %>"
                        height="<%= connector_height - 8 %>"
                        rx="<%= (connector_height - 8) / 2.0 %>"
                        fill="<%= row[:color] %>"
                        opacity="0.16"
                      />
                      <circle cx="<%= x - 8 %>" cy="<%= y %>" r="<%= selected_station ? 2.5 : 2 %>" fill="white" stroke="<%= row[:color] %>" stroke-width="1.5" />
                      <circle cx="<%= x %>" cy="<%= y %>" r="<%= selected_station ? 2.5 : 2 %>" fill="white" stroke="<%= row[:color] %>" stroke-width="1.5" />
                      <circle cx="<%= x + 8 %>" cy="<%= y %>" r="<%= selected_station ? 2.5 : 2 %>" fill="white" stroke="<%= row[:color] %>" stroke-width="1.5" />
                    <% elsif station.branch? %>
                      <circle cx="<%= x %>" cy="<%= y %>" r="<%= selected_station ? 8 : 6.5 %>" fill="<%= row[:color] %>" filter="url(#shadow)" />
                      <rect x="<%= x - (selected_station ? 5 : 4.5) %>" y="<%= y - (selected_station ? 5 : 4.5) %>" width="<%= selected_station ? 10 : 9 %>" height="<%= selected_station ? 10 : 9 %>" rx="2" fill="white" transform="rotate(45 <%= x %> <%= y %>)" />
                    <% elsif station.gate? %>
                      <circle cx="<%= x %>" cy="<%= y %>" r="<%= selected_station ? 8 : 6.5 %>" fill="<%= row[:color] %>" filter="url(#shadow)" />
                      <rect x="<%= x - (selected_station ? 5 : 4.5) %>" y="<%= y - (selected_station ? 3 : 2.5) %>" width="<%= selected_station ? 10 : 9 %>" height="<%= selected_station ? 6 : 5 %>" rx="2.5" fill="white" />
                    <% elsif port_shape_station %>
                      <% diamond_size = selected_station ? 12 : 10.5 %>
                      <polygon
                        points="<%= [ [x, y - diamond_size], [x + diamond_size, y], [x, y + diamond_size], [x - diamond_size, y] ].map { |px, py| "#{px},#{py}" }.join(' ') %>"
                        fill="white"
                        stroke="#111827"
                        stroke-width="<%= selected_station ? 4 : 3.2 %>"
                        filter="url(#shadow)"
                      />
                      <% if station.port_entry? %>
                        <polygon
                          points="<%= [ [x, y - diamond_size], [x + diamond_size, y], [x - diamond_size, y] ].map { |px, py| "#{px},#{py}" }.join(' ') %>"
                          fill="#111827"
                        />
                        <line x1="<%= x - diamond_size * 0.64 %>" y1="<%= y %>" x2="<%= x + diamond_size * 0.64 %>" y2="<%= y %>" stroke="#111827" stroke-width="2" stroke-linecap="round" />
                      <% else %>
                        <polygon
                          points="<%= [ [x, y + diamond_size], [x + diamond_size, y], [x - diamond_size, y] ].map { |px, py| "#{px},#{py}" }.join(' ') %>"
                          fill="#111827"
                        />
                        <line x1="<%= x - diamond_size * 0.64 %>" y1="<%= y %>" x2="<%= x + diamond_size * 0.64 %>" y2="<%= y %>" stroke="#111827" stroke-width="2" stroke-linecap="round" />
                      <% end %>
                    <% else %>
                      <circle
                        cx="<%= x %>"
                        cy="<%= y %>"
                        r="<%= selected_station ? 10 : 9 %>"
                        fill="white"
                        stroke="#111827"
                        stroke-width="<%= selected_station ? 4 : 3.2 %>"
                        filter="url(#shadow)"
                        class="transition-all duration-300 transform origin-center"
                        style="transform-box: fill-box;"
                        onmouseover="this.setAttribute('r', '<%= selected_station ? 11 : 10 %>')"
                        onmouseout="this.setAttribute('r', '<%= selected_station ? 10 : 9 %>')"
                      />
                    <% end %>
                    <% if marker_label.present? && !in_shared_group %>
                      <text x="<%= x %>" y="<%= y - 36 %>" text-anchor="middle" font-size="11" font-weight="900" fill="<%= marker_color %>"><%= marker_label %></text>
                    <% end %>
                    <% unless in_shared_group %>
                      <text x="<%= x %>" y="<%= y + 48 %>" text-anchor="middle" font-size="14" font-weight="800" fill="<%= selected_station ? row[:color] : "#1e293b" %>" style="transition: fill 0.2s;" onmouseover="this.setAttribute('fill', '<%= row[:color] %>')" onmouseout="this.setAttribute('fill', '<%= selected_station ? row[:color] : "#1e293b" %>')"><%= station.name %></text>
                      <text x="<%= x %>" y="<%= y + 68 %>" text-anchor="middle" font-size="12" font-weight="600" fill="<%= selected_station ? "#4338ca" : "#64748b" %>"><%= station.connector? ? "Collegamento" : station.canonical_experience&.name %></text>
                    <% end %>
                  </a>
                <% end %>
              <% end %>
              <% if @edit_mode && @active_panel.in?(%w[new_line new_station]) %>
                <rect x="0" y="0" width="<%= @map_width %>" height="<%= @map_height %>" fill="transparent" style="cursor: crosshair;" data-action="mousemove->land-map-builder#move mouseleave->land-map-builder#leave click->land-map-builder#pick" />
              <% end %>
              <circle cx="0" cy="0" r="16" fill="rgba(99,102,241,0.14)" stroke="#4f46e5" stroke-width="3" class="hidden pointer-events-none" data-land-map-builder-target="placementMarker" />
              <circle cx="0" cy="0" r="34" fill="rgba(37,99,235,0.10)" stroke="#2563eb" stroke-width="5" class="hidden pointer-events-none" data-land-map-builder-target="candidateMarker" />
            </svg>
          <% else %>
            <svg viewBox="0 0 1200 720" style="width: 100%; min-width: 960px; height: auto; display: block;" data-land-map-builder-target="svg" data-action="click->land-map-builder#backgroundClick">
              <defs>
                <pattern id="land-grid-empty" width="60" height="60" patternUnits="userSpaceOnUse">
                  <path d="M 60 0 L 0 0 0 60" fill="none" stroke="rgba(255,255,255,0.6)" stroke-width="2" />
                  <circle cx="0" cy="0" r="1.5" fill="#cbd5e1" />
                </pattern>
              </defs>
              <rect width="100%" height="100%" fill="url(#land-grid-empty)" />
              <g>
                <text x="600" y="300" text-anchor="middle" font-size="32" font-weight="900" fill="#475569">Mappa vuota</text>
                <text x="600" y="340" text-anchor="middle" font-size="16" font-weight="600" fill="#64748b">
                  <% if @edit_mode && @active_panel == "new_line" %>
                    Clicca per posizionare la prima station della nuova line.
                  <% else %>
                    Inizia creando la prima line dalla mappa.
                  <% end %>
                </text>
              </g>
              <% if @edit_mode && @active_panel.in?(%w[new_line new_station]) && preview_origin.present? %>
                <line
                  x1="<%= preview_origin[:x] %>"
                  y1="<%= preview_origin[:y] %>"
                  x2="<%= preview_origin[:x] %>"
                  y2="<%= preview_origin[:y] %>"
                  stroke="#0f172a"
                  stroke-width="5"
                  stroke-dasharray="10 8"
                  stroke-linecap="round"
                  opacity="0.55"
                  class="hidden pointer-events-none"
                  data-land-map-builder-target="previewLine"
                  data-origin-x="<%= preview_origin[:x] %>"
                  data-origin-y="<%= preview_origin[:y] %>"
                />
              <% end %>
              <% if @edit_mode && @active_panel.in?(%w[new_line new_station]) %>
                <rect x="0" y="0" width="1200" height="720" fill="transparent" style="cursor: crosshair;" data-action="mousemove->land-map-builder#move mouseleave->land-map-builder#leave click->land-map-builder#pick" />
              <% end %>
              <circle cx="0" cy="0" r="16" fill="rgba(99,102,241,0.14)" stroke="#4f46e5" stroke-width="3" class="hidden pointer-events-none" data-land-map-builder-target="placementMarker" />
              <circle cx="0" cy="0" r="34" fill="rgba(37,99,235,0.10)" stroke="#2563eb" stroke-width="5" class="hidden pointer-events-none" data-land-map-builder-target="candidateMarker" />
            </svg>
          <% end %>
          </div>
        </div>
      </div>

      <div class="mt-4 rounded-[1.5rem] border border-slate-200/60 bg-white px-6 py-4 shadow-sm">
        <div class="flex flex-wrap items-center gap-x-5 gap-y-2 text-xs font-bold text-slate-600">
          <% if @selected_line.present? %>
            <% selected_line_color = @line_map_rows.find { |row| row[:line] == @selected_line }&.dig(:color) || "#6366f1" %>
            <span class="inline-flex items-center gap-2">
              <span class="inline-block h-3 w-3 rounded-full" style="background: <%= selected_line_color %>;"></span>
              Line selezionata: <span class="text-slate-900"><%= @selected_line.name %></span>
            </span>
          <% end %>
          <% if @selected_station.present? %>
            <span class="inline-flex items-center gap-2">
              <span class="inline-flex h-5 min-w-5 items-center justify-center rounded-full bg-sky-100 px-1.5 text-[10px] font-black text-sky-700">
                <%= @selected_station.opening? ? "IN" : (@selected_station.closing? ? "OUT" : "•") %>
              </span>
              Station selezionata: <span class="text-slate-900"><%= @selected_station.name %></span>
            </span>
          <% end %>
          <span><span class="inline-block px-1.5 py-0.5 bg-emerald-100 text-emerald-800 rounded font-black text-[9px] mr-1">IN</span>Apertura</span>
          <span><span class="inline-block px-1.5 py-0.5 bg-rose-100 text-rose-800 rounded font-black text-[9px] mr-1">OUT</span>Chiusura</span>
          <span><span class="inline-block px-1.5 py-0.5 bg-amber-100 text-amber-800 rounded font-black text-[9px] mr-1">BR</span>Ramo</span>
          <span><span class="inline-block px-1.5 py-0.5 bg-sky-100 text-sky-800 rounded font-black text-[9px] mr-1">GT</span>Gate</span>
        </div>
      </div>

      <% if @edit_mode && @active_panel == "new_line" %>
        <%= form_with url: creator_port_lines_path(@port), method: :post, scope: :line, class: "hidden fixed inset-0 z-50 items-center justify-center bg-slate-950/35 p-4", data: { land_map_builder_target: "lineModal", action: "click->land-map-builder#closeModal", close_path: land_map_creator_port_path(@port, edit: 1) } do |form| %>
          <%= form.hidden_field :source, value: "land_map" %>
          <div class="w-full max-w-2xl max-h-[90vh] overflow-y-auto rounded-[1.5rem] bg-white p-6 shadow-2xl border border-slate-200" data-land-map-builder-target="linePanel">
            <div class="flex items-center justify-between gap-4 mb-5">
              <div>
                <h3 class="text-xl font-black text-slate-900" data-land-map-builder-target="lineTitle">Nuova Line</h3>
                <p class="text-sm text-slate-500 mt-1">Completa line, prima station ed experience iniziale. `Esc` chiude il modal.</p>
              </div>
              <%= link_to "Annulla", land_map_creator_port_path(@port, edit: 1), class: "inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white text-slate-700 font-bold border border-slate-200 hover:bg-slate-50 text-xs" %>
            </div>

            <div class="hidden" data-land-map-builder-target="lineForm">
              <%= form.hidden_field :initial_station_map_x, data: { land_map_builder_target: "lineX" } %>
              <%= form.hidden_field :initial_station_map_y, data: { land_map_builder_target: "lineY" } %>
              <%= form.hidden_field :source_station_id, value: "", data: { land_map_builder_target: "lineSourceStation" } %>
            </div>

            <div class="space-y-3 hidden" data-land-map-builder-target="lineForm">
              <div class="hidden rounded-xl border border-indigo-100 bg-indigo-50 px-4 py-3 text-xs font-bold text-indigo-700" data-land-map-builder-target="lineAttachSummary">
                La nuova line partira' da una station esistente. La prima station nascera' come collegamento, senza experience autonoma.
              </div>
              <div class="rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-xs font-bold text-slate-600" data-land-map-builder-target="lineFreeSummary">
                La nuova line partira' da un punto libero e la prima station sara' principale.
              </div>
              <div class="space-y-1.5">
                <label class="text-xs font-black uppercase tracking-wider text-slate-500">Nome line</label>
                <%= form.text_field :name, placeholder: "Es. Percorso base postura", required: true, class: "w-full rounded-xl border-slate-200 bg-white shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm py-2.5 px-4" %>
              </div>
              <div class="grid grid-cols-1 md:grid-cols-[1fr_auto] gap-3 items-end">
                <div class="space-y-1.5">
                  <label class="text-xs font-black uppercase tracking-wider text-slate-500">Tipo line</label>
                  <%= form.select :line_kind, options_for_select(line_kind_options, default_line_kind), {}, required: true, class: "w-full rounded-xl border-slate-200 bg-white shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm py-2.5 px-4" %>
                </div>
                <div class="space-y-1.5">
                  <label class="text-xs font-black uppercase tracking-wider text-slate-500">Colore</label>
                  <%= form.color_field :color, class: "w-full md:w-20 h-11 rounded-xl border-slate-200 bg-white shadow-sm cursor-pointer" %>
                </div>
              </div>
              <div class="h-px w-full bg-indigo-100 my-1"></div>
              <div class="space-y-1.5">
                <label class="text-xs font-black uppercase tracking-wider text-slate-500">Nome prima station</label>
                <%= form.text_field :initial_station_name, placeholder: "Es. Ingresso", required: true, class: "w-full rounded-xl border-slate-200 bg-white shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm py-2.5 px-4", data: { land_map_builder_target: "lineInitialName" } %>
              </div>
              <div class="space-y-1.5">
                <label class="text-xs font-black uppercase tracking-wider text-slate-500">Tipo prima station</label>
                <%= form.select :initial_station_kind, options_for_select(station_kind_options, "normal"), {}, required: true, class: "w-full rounded-xl border-slate-200 bg-white shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm py-2.5 px-4", data: { land_map_builder_target: "lineInitialKind" } %>
              </div>
              <div class="hidden rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-xs font-bold text-slate-600" data-land-map-builder-target="lineAttachSummary">
                Se confermi l'aggancio, la prima station della line nascera' come station di collegamento.
              </div>
              <div class="rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-xs font-bold text-slate-600" data-land-map-builder-target="lineFreeSummary">
                Alla prima station verra' collegata automaticamente una experience iniziale, che potrai rifinire dopo.
              </div>
            </div>

            <div class="pt-5 hidden" data-land-map-builder-target="lineForm">
              <%= form.submit "Crea Linea", class: "w-full py-3 px-4 bg-indigo-600 hover:bg-indigo-700 text-white font-bold rounded-xl shadow-md transition-all cursor-pointer" %>
            </div>
          </div>
        <% end %>
      <% elsif @edit_mode && @active_panel == "new_station" && @lines.any? %>
        <%= form_with url: land_map_station_creator_port_path(@port), method: :post, scope: :station, class: "hidden fixed inset-0 z-50 items-center justify-center bg-slate-950/35 p-4", data: { land_map_builder_target: "stationModal", action: "click->land-map-builder#closeModal", close_path: land_map_creator_port_path(@port, edit: 1, line_id: @selected_line&.id) } do |form| %>
          <div class="w-full max-w-2xl max-h-[90vh] overflow-y-auto rounded-[1.5rem] bg-white p-6 shadow-2xl border border-slate-200" data-land-map-builder-target="stationPanel">
            <div class="flex items-center justify-between gap-4 mb-5">
              <div>
                <h3 class="text-xl font-black text-slate-900" data-land-map-builder-target="stationTitle">Nuova Station</h3>
                <p class="text-sm text-slate-500 mt-1">Completa il nodo e collega o crea la sua experience. `Esc` chiude il modal.</p>
              </div>
              <%= link_to "Annulla", land_map_creator_port_path(@port, edit: 1, line_id: @selected_line&.id), class: "inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white text-slate-700 font-bold border border-slate-200 hover:bg-slate-50 text-xs" %>
            </div>

            <div class="hidden" data-land-map-builder-target="stationForm">
              <%= form.hidden_field :map_x, data: { land_map_builder_target: "stationX" } %>
              <%= form.hidden_field :map_y, data: { land_map_builder_target: "stationY" } %>
              <%= form.hidden_field :source_station_id, value: @selected_station&.id, data: { land_map_builder_target: "stationSourceStation" } %>
              <%= form.hidden_field :relative_position, value: default_station_relative_position, data: { land_map_builder_target: "stationRelativePosition" } %>
              <%= form.hidden_field :link_station_id, value: "", data: { land_map_builder_target: "stationLinkStation" } %>
            </div>

            <div class="space-y-3 hidden" data-land-map-builder-target="stationForm" data-controller="experience-mode">
              <%= form.hidden_field :line_id, value: @selected_line&.id %>
              <% if @selected_line.present? %>
                <div class="rounded-xl border border-emerald-100 bg-emerald-50 px-4 py-3 text-xs font-bold text-emerald-700">
                  Line attiva: <span class="text-slate-900"><%= @selected_line.name %></span>
                  <% if @selected_station.present? %>
                    <span class="text-slate-500"> · da station <%= @selected_station.name %></span>
                  <% end %>
                </div>
              <% end %>
              <div class="hidden space-y-3" data-land-map-builder-target="stationSourceOptions">
                <div class="space-y-1.5">
                  <label class="text-xs font-black uppercase tracking-wider text-slate-500">Relazione con la station selezionata</label>
                  <div class="inline-flex w-full rounded-full bg-slate-100 p-1">
                    <button type="button" class="inline-flex items-center justify-center rounded-full px-4 py-2 text-xs font-black" data-station-relative-position="before" data-land-map-builder-target="stationBeforeButton" data-action="click->land-map-builder#setStationRelativePosition">
                      Prima
                    </button>
                    <button type="button" class="inline-flex items-center justify-center rounded-full px-4 py-2 text-xs font-black" data-station-relative-position="after" data-land-map-builder-target="stationAfterButton" data-action="click->land-map-builder#setStationRelativePosition">
                      Dopo
                    </button>
                  </div>
                </div>
                <div class="rounded-xl border border-emerald-100 bg-emerald-50 px-4 py-3 text-xs font-bold text-emerald-700" data-land-map-builder-target="stationModeSummary">
                  La nuova station verra' aggiunta dopo la station selezionata.
                </div>
              </div>
              <div class="space-y-1.5">
                <label class="text-xs font-black uppercase tracking-wider text-slate-500">Nome station</label>
                <%= form.text_field :name, placeholder: "Es. Check iniziale", required: true, class: "w-full rounded-xl border-slate-200 bg-white shadow-sm focus:border-emerald-500 focus:ring-emerald-500 text-sm py-2.5 px-4" %>
              </div>
              <div class="space-y-1.5">
                <label class="text-xs font-black uppercase tracking-wider text-slate-500">Tipo station</label>
                <%= form.select :station_kind, options_for_select(station_kind_options, default_station_kind), {}, required: true, class: "w-full rounded-xl border-slate-200 bg-white shadow-sm focus:border-emerald-500 focus:ring-emerald-500 text-sm py-2.5 px-4" %>
              </div>
              <div class="space-y-1.5" data-controller="experience-picker" data-experience-picker-options-value="<%= port_picker_options %>">
                <label class="text-xs font-black uppercase tracking-wider text-slate-500">Port collegato opzionale</label>
                <%= form.hidden_field :link_port_id, value: default_existing_port_id, data: { experience_picker_target: "idField" } %>
                <%= text_field_tag "station[link_port_search]", default_existing_port_name, list: "station-port-options", placeholder: "Cerca un port da collegare", class: "w-full rounded-xl border-slate-200 bg-white shadow-sm focus:border-emerald-500 focus:ring-emerald-500 text-sm py-2.5 px-4", data: { experience_picker_target: "search", action: "input->experience-picker#input change->experience-picker#change" } %>
                <datalist id="station-port-options">
                  <% @linkable_ports.each do |port| %>
                    <option value="<%= port.name %>"></option>
                  <% end %>
                </datalist>
              </div>
              <div class="h-px w-full bg-emerald-100 my-1"></div>
              <div class="space-y-1.5">
                <label class="text-xs font-black uppercase tracking-wider text-slate-500">Modalita' experience</label>
                <%= hidden_field_tag "station[experience_mode]", "existing", data: { experience_mode_target: "mode" } %>
                <div class="inline-flex w-full rounded-full bg-slate-100 p-1">
                  <button type="button" class="inline-flex items-center justify-center rounded-full bg-emerald-600 px-4 py-2 text-xs font-black text-white shadow-sm" data-mode="existing" data-experience-mode-target="existingButton" data-action="click->experience-mode#setMode">
                    Usa experience esistente
                  </button>
                  <button type="button" class="inline-flex items-center justify-center rounded-full bg-white px-4 py-2 text-xs font-black text-slate-600 border border-slate-200" data-mode="new" data-experience-mode-target="newButton" data-action="click->experience-mode#setMode">
                    Crea nuova experience
                  </button>
                </div>
              </div>
              <div class="space-y-1.5" data-experience-mode-target="existing" data-controller="experience-picker" data-experience-picker-options-value="<%= experience_picker_options %>">
                <label class="text-xs font-black uppercase tracking-wider text-slate-500">Experience esistente</label>
                <%= form.hidden_field :experience_id, value: default_existing_experience_id, data: { experience_mode_target: "existingInput", experience_picker_target: "idField" } %>
                <%= text_field_tag "station[experience_search]", default_existing_experience_name, list: "station-experience-options", placeholder: "Cerca una experience esistente", class: "w-full rounded-xl border-slate-200 bg-white shadow-sm focus:border-emerald-500 focus:ring-emerald-500 text-sm py-2.5 px-4", data: { experience_mode_target: "existingInput", experience_picker_target: "search", action: "input->experience-picker#input change->experience-picker#change" } %>
                <datalist id="station-experience-options">
                  <% @experiences.each do |experience| %>
                    <option value="<%= experience.name %>"></option>
                  <% end %>
                </datalist>
              </div>
              <div class="space-y-1.5 hidden" data-experience-mode-target="new">
                <label class="text-xs font-black uppercase tracking-wider text-slate-500">Nuova experience</label>
                <%= form.text_field :new_experience_name, placeholder: "Es. Routine iniziale", class: "w-full rounded-xl border-slate-200 bg-white shadow-sm focus:border-emerald-500 focus:ring-emerald-500 text-sm py-2.5 px-4", data: { experience_mode_target: "newInput" } %>
              </div>
              <div class="space-y-1.5 hidden" data-experience-mode-target="new">
                <label class="text-xs font-black uppercase tracking-wider text-slate-500">Tipo experience</label>
                <%= form.select :new_experience_kind, options_for_select(experience_kind_options, Experience.experience_kinds.keys.first), {}, include_blank: false, class: "w-full rounded-xl border-slate-200 bg-white shadow-sm focus:border-emerald-500 focus:ring-emerald-500 text-sm py-2.5 px-4", data: { experience_mode_target: "newInput" } %>
              </div>
              <div class="space-y-1.5">
                <label class="inline-flex items-center gap-3 text-sm font-bold text-slate-700">
                  <%= form.check_box :port_entry, class: "rounded border-slate-300 text-emerald-600 focus:ring-emerald-500" %>
                  Entry station del port
                </label>
                <p class="text-[11px] font-bold text-slate-500">Attivalo se il port puo' iniziare da questa station.</p>
              </div>
            </div>

            <div class="pt-5 hidden" data-land-map-builder-target="stationForm">
              <%= form.submit "Aggiungi Nodo", class: "w-full py-3 px-4 bg-slate-800 hover:bg-slate-900 text-white font-bold rounded-xl shadow-md transition-all cursor-pointer" %>
            </div>
          </div>
        <% end %>
      <% elsif @edit_mode && @active_panel == "edit_line" && @selected_line.present? %>
        <div class="fixed inset-0 z-50 flex items-center justify-center bg-slate-950/35 p-4">
          <div class="w-full max-w-2xl max-h-[90vh] overflow-y-auto rounded-[1.5rem] bg-white p-6 shadow-2xl border border-slate-200">
            <div class="flex items-center justify-between gap-4 mb-5">
              <div>
                <h3 class="text-xl font-black text-slate-900">Modifica Line</h3>
                <p class="text-sm text-slate-500 mt-1">Aggiorna dati base e colore del tracciato.</p>
              </div>
              <%= link_to "Chiudi", land_map_creator_port_path(@port, edit: 1, line_id: @selected_line.id), class: "inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white text-slate-700 font-bold border border-slate-200 hover:bg-slate-50 text-xs" %>
            </div>

            <%= form_with model: [:creator, @port, @selected_line], class: "space-y-4" do |form| %>
              <div class="space-y-3">
                <div class="space-y-1.5">
                  <label class="text-xs font-black uppercase tracking-wider text-slate-500">Nome line</label>
                  <%= form.text_field :name, placeholder: "Nome line", required: true, class: "w-full rounded-xl border-slate-200 bg-white shadow-sm focus:border-amber-500 focus:ring-amber-500 text-sm py-2.5 px-4" %>
                </div>
                <div class="space-y-1.5">
                  <label class="text-xs font-black uppercase tracking-wider text-slate-500">Tipo line</label>
                  <%= form.select :line_kind, line_kind_options, {}, required: true, class: "w-full rounded-xl border-slate-200 bg-white shadow-sm focus:border-amber-500 focus:ring-amber-500 text-sm py-2.5 px-4" %>
                </div>
                <div class="space-y-1.5">
                  <label class="text-xs font-black uppercase tracking-wider text-slate-500">Colore line</label>
                  <%= form.color_field :color, class: "w-full h-11 rounded-xl border-slate-200 bg-white shadow-sm cursor-pointer" %>
                </div>
                <div class="space-y-1.5">
                  <label class="text-xs font-black uppercase tracking-wider text-slate-500">Posizione</label>
                  <%= form.number_field :position, min: 0, step: 1, placeholder: "Posizione", class: "w-full rounded-xl border-slate-200 bg-white shadow-sm focus:border-amber-500 focus:ring-amber-500 text-sm py-2.5 px-4" %>
                </div>
              </div>

              <div class="grid gap-3 pt-2">
                <%= form.submit "Salva Line", class: "w-full py-3 px-4 bg-amber-500 hover:bg-amber-600 text-white font-bold rounded-xl shadow-md transition-all cursor-pointer" %>
                <%= link_to land_map_creator_port_path(@port, edit: 1, panel: "new_station", line_id: @selected_line.id), class: "inline-flex items-center justify-center gap-2 px-4 py-3 rounded-xl bg-white border border-slate-200 text-slate-700 font-bold hover:bg-slate-50 transition-colors text-sm" do %>
                  <span class="material-symbols-outlined text-[18px]">add_circle</span> Aggiungi station a questa line
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      <% elsif @edit_mode && @active_panel == "edit_station" && @selected_station.present? && @selected_line.present? %>
        <div class="fixed inset-0 z-50 flex items-center justify-center bg-slate-950/35 p-4">
          <div class="w-full max-w-2xl max-h-[90vh] overflow-y-auto rounded-[1.5rem] bg-white p-6 shadow-2xl border border-slate-200">
            <div class="flex items-center justify-between gap-4 mb-5">
              <div>
                <h3 class="text-xl font-black text-slate-900">Modifica Station</h3>
                <p class="text-sm text-slate-500 mt-1">Aggiorna nodo, coordinate e collegamenti senza uscire dalla mappa.</p>
              </div>
              <%= link_to "Chiudi", land_map_creator_port_path(@port, edit: 1, line_id: @selected_line.id), class: "inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white text-slate-700 font-bold border border-slate-200 hover:bg-slate-50 text-xs" %>
            </div>

            <div class="mb-5 rounded-xl border border-sky-200 bg-sky-50 px-4 py-3">
              <div class="text-[11px] font-black uppercase tracking-wider text-sky-500">Station selezionata</div>
              <div class="mt-1 flex items-center gap-2">
                <span class="inline-flex items-center justify-center w-6 h-6 rounded-full text-[11px] font-black text-white" style="background: <%= @line_map_rows.find { |row| row[:line] == @selected_line }&.dig(:color) || "#0ea5e9" %>;">
                  <%= @selected_station.opening? ? "IN" : (@selected_station.closing? ? "OUT" : "•") %>
                </span>
                <strong class="text-slate-900"><%= @selected_station.name %></strong>
              </div>
              <% if @selected_station.link_station.present? %>
                <div class="mt-3 text-xs font-medium text-sky-700">
                  Incrocio attivo con: <strong><%= @selected_station.link_station.name %></strong>
                </div>
              <% end %>
              <% if @selected_station.link_port.present? %>
                <div class="mt-1 text-xs font-medium text-orange-600">
                  Porta verso: <strong><%= @selected_station.link_port.name %></strong>
                </div>
              <% end %>
            </div>

            <%= form_with model: [:creator, @port, @selected_line, @selected_station], class: "space-y-4" do |form| %>
              <%= hidden_field_tag :return_to, "land_map" %>
              <div class="space-y-3">
                <div class="space-y-1.5" data-controller="experience-picker" data-experience-picker-options-value="<%= experience_picker_options %>">
                  <label class="text-xs font-black uppercase tracking-wider text-slate-500">Experience</label>
                  <%= form.hidden_field :experience_id, data: { experience_picker_target: "idField" } %>
                  <%= text_field_tag "station[experience_search]", @selected_station.canonical_experience&.name, list: "edit-station-experience-options", placeholder: "Cerca una experience esistente", required: true, class: "w-full rounded-xl border-slate-200 bg-white shadow-sm focus:border-sky-500 focus:ring-sky-500 text-sm py-2.5 px-4", data: { experience_picker_target: "search", action: "input->experience-picker#input change->experience-picker#change" } %>
                  <datalist id="edit-station-experience-options">
                    <% @experiences.each do |experience| %>
                      <option value="<%= experience.name %>"></option>
                    <% end %>
                  </datalist>
                </div>
                <div class="space-y-1.5">
                  <label class="text-xs font-black uppercase tracking-wider text-slate-500">Nome station</label>
                  <%= form.text_field :name, placeholder: "Nome station", required: true, class: "w-full rounded-xl border-slate-200 bg-white shadow-sm focus:border-sky-500 focus:ring-sky-500 text-sm py-2.5 px-4" %>
                </div>
                <div class="space-y-1.5">
                  <label class="text-xs font-black uppercase tracking-wider text-slate-500">Slug</label>
                  <%= form.text_field :slug, placeholder: "slug-station", class: "w-full rounded-xl border-slate-200 bg-white shadow-sm focus:border-sky-500 focus:ring-sky-500 text-sm py-2.5 px-4" %>
                </div>
                <div class="space-y-1.5">
                  <label class="text-xs font-black uppercase tracking-wider text-slate-500">Tipo station</label>
                  <%= form.select :station_kind, station_kind_options, {}, required: true, class: "w-full rounded-xl border-slate-200 bg-white shadow-sm focus:border-sky-500 focus:ring-sky-500 text-sm py-2.5 px-4" %>
                </div>
                <div class="space-y-1">
                  <label class="text-xs font-black uppercase tracking-wider text-slate-500">Ordine nel nodo condiviso</label>
                  <%= form.number_field :link_order, step: 1, placeholder: "0", class: "w-full rounded-xl border-slate-200 bg-white shadow-sm focus:border-sky-500 focus:ring-sky-500 text-sm py-2.5 px-4" %>
                </div>
                <div class="space-y-1">
                  <label class="text-xs font-black uppercase tracking-wider text-slate-500">Angolo nodo condiviso</label>
                  <%= form.select :shared_group_angle, options_for_select(shared_group_angle_options, @selected_station.primary_station.shared_group_angle), {}, class: "w-full rounded-xl border-slate-200 bg-white shadow-sm focus:border-sky-500 focus:ring-sky-500 text-sm py-2.5 px-4" %>
                  <p class="text-[11px] font-bold text-slate-500">L'angolo viene salvato sulla station principale del nodo condiviso.</p>
                </div>
                <div class="space-y-1.5">
                  <label class="text-xs font-black uppercase tracking-wider text-slate-500">Posizione nella line</label>
                  <%= form.number_field :position, min: 0, step: 1, placeholder: "Posizione", class: "w-full rounded-xl border-slate-200 bg-white shadow-sm focus:border-sky-500 focus:ring-sky-500 text-sm py-2.5 px-4" %>
                </div>
                <div class="grid grid-cols-2 gap-3">
                  <div class="space-y-1.5">
                    <label class="text-xs font-black uppercase tracking-wider text-slate-500">Coordinata X</label>
                    <%= form.number_field :map_x, placeholder: "Coord X", step: 1, class: "w-full rounded-xl border-slate-200 bg-white shadow-sm focus:border-sky-500 focus:ring-sky-500 text-sm py-2.5 px-4" %>
                  </div>
                  <div class="space-y-1.5">
                    <label class="text-xs font-black uppercase tracking-wider text-slate-500">Coordinata Y</label>
                    <%= form.number_field :map_y, placeholder: "Coord Y", step: 1, class: "w-full rounded-xl border-slate-200 bg-white shadow-sm focus:border-sky-500 focus:ring-sky-500 text-sm py-2.5 px-4" %>
                  </div>
                </div>
                <div class="space-y-1.5">
                  <label class="text-xs font-black uppercase tracking-wider text-slate-500">Link ad altra station</label>
                  <%= form.collection_select :link_station_id, @linkable_stations, :id, :name, { include_blank: "Nessun link station" }, class: "w-full rounded-xl border-slate-200 bg-white shadow-sm focus:border-sky-500 focus:ring-sky-500 text-sm py-2.5 px-4" %>
                </div>
                <% if @selected_station.link_station.present? %>
                  <p class="text-xs font-bold text-slate-500">Lascia vuoto per sganciare il collegamento dalla station principale.</p>
                <% end %>
                <div class="space-y-1.5">
                  <label class="text-xs font-black uppercase tracking-wider text-slate-500">Link ad altro port</label>
                  <%= form.collection_select :link_port_id, @linkable_ports, :id, :name, { include_blank: "Nessun link port" }, class: "w-full rounded-xl border-slate-200 bg-white shadow-sm focus:border-sky-500 focus:ring-sky-500 text-sm py-2.5 px-4" %>
                </div>
                <% if @selected_station.link_port.present? %>
                  <p class="text-xs font-bold text-slate-500">Lascia vuoto per rimuovere il passaggio verso l'altro port.</p>
                <% end %>
                <div class="space-y-1.5">
                  <label class="inline-flex items-center gap-3 text-sm font-bold text-slate-700">
                    <%= form.check_box :port_entry, class: "rounded border-slate-300 text-sky-600 focus:ring-sky-500" %>
                    Entry station del port
                  </label>
                  <p class="text-[11px] font-bold text-slate-500">Attivalo se il port puo' iniziare da questa station.</p>
                </div>
                <div class="space-y-1.5">
                  <label class="text-xs font-black uppercase tracking-wider text-slate-500">Descrizione</label>
                  <%= form.text_area :description, rows: 4, placeholder: "Descrizione della station nel percorso", class: "w-full rounded-xl border-slate-200 bg-white shadow-sm focus:border-sky-500 focus:ring-sky-500 text-sm py-2.5 px-4" %>
                </div>
              </div>

              <div class="grid gap-3 pt-2">
                <%= form.submit "Salva Station", class: "w-full py-3 px-4 bg-sky-600 hover:bg-sky-700 text-white font-bold rounded-xl shadow-md transition-all cursor-pointer" %>
                <%= link_to "Apri pagina edit completa", edit_creator_port_line_station_path(@port, @selected_line, @selected_station), class: "inline-flex items-center justify-center gap-2 px-4 py-3 rounded-xl bg-white border border-slate-200 text-slate-700 font-bold hover:bg-slate-50 transition-colors text-sm" %>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>
