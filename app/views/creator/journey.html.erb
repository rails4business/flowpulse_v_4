<% content_for :title, "Trail creator" %>

<section class="dashboard-shell">
  <div class="app-layout">
    <%= render "shared/app_sidebar" %>

    <div class="dashboard-card">
      <p class="eyebrow">Creator</p>
      <h1 style="margin-bottom: 0.35rem; max-width: none; white-space: nowrap;">Trail creator</h1>
      <p>
        Questa vista sara' il punto di lavoro del trail template. Per ora mantiene la shell autenticata
        e collega il trail statico come riferimento.
      </p>

      <div class="tree-panel">
        <div class="tree-title">Focus</div>
        <div class="tree-preview">
          <div>• fasi exploration / validation / service</div>
          <div>• eventi collegati al trail</div>
          <div>• risorse e materiali del percorso</div>
        </div>
      </div>

      <div class="dashboard-actions">
        <div class="admin-section">
          <h2>Riferimento attuale</h2>
          <div class="admin-list">
            <article class="admin-list-item">
              <div class="admin-list-copy">
                <strong>Mockup statico Rails4Business</strong>
                <p>Base temporanea per la vista di dettaglio del trail creator.</p>
              </div>
              <div class="admin-list-actions">
                <a href="/flowpulse_v_4/3_rails4b.html" class="btn btn-secondary">Apri riferimento</a>
              </div>
            </article>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
