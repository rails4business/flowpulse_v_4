<%= form_with(model: [:creator, @port, experience], class: "form-standard") do |form| %>
  <% if experience.errors.any? %>
    <div style="color: #b91c1c; margin-bottom: 1rem;">
      <h4 style="margin: 0 0 0.5rem;">Ci sono errori:</h4>
      <ul style="margin: 0; padding-left: 1.2rem;">
        <% experience.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-grid">
    <div class="field-group">
      <%= form.label :name, "Nome experience" %>
      <%= form.text_field :name, required: true, placeholder: "Valutazione iniziale" %>
    </div>

    <div class="field-group">
      <%= form.label :slug, "Slug" %>
      <%= form.text_field :slug, placeholder: "valutazione-iniziale" %>
    </div>

    <div class="field-group">
      <%= form.label :experience_kind, "Tipo experience" %>
      <%= form.select :experience_kind, Experience.experience_kinds.keys.map { |key| [key.humanize, key] }, {}, required: true %>
    </div>

    <div class="field-group">
      <%= form.label :position, "Posizione" %>
      <%= form.number_field :position, min: 0, step: 1 %>
    </div>

    <div class="field-group">
      <%= form.label :parent_experience_id, "Experience parent" %>
      <%= form.collection_select :parent_experience_id, @parent_experiences, :id, :name, { include_blank: "Nessuna parent experience" } %>
    </div>
  </div>

  <div style="margin: 2rem 0 1.5rem; padding-top: 1.5rem; border-top: 1px solid #e2e8f0;">
    <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem;">
      <span class="material-symbols-outlined" style="color: #4f46e5;">article</span>
      <div>
        <strong style="display: block; color: #0f172a;">Content della experience</strong>
        <p style="margin: 0.2rem 0 0; color: #64748b; font-size: 0.85rem;">Layer editoriale condiviso per testo, media, visibilita' e pubblicazione.</p>
      </div>
    </div>

    <%= form.fields_for :content do |content_form| %>
      <div class="form-grid">
        <div class="field-group">
          <%= content_form.label :subtitle, "Sottotitolo" %>
          <%= content_form.text_field :subtitle, placeholder: "Sottotitolo editoriale della experience" %>
        </div>

        <div class="field-group">
          <%= content_form.label :visibility, "Visibilita'" %>
          <%= content_form.select :visibility, Content.visibilities.keys.map { |key| [key.humanize, key] }, {} %>
        </div>

        <div class="field-group field-group-full">
          <%= content_form.label :description, "Descrizione editoriale" %>
          <%= content_form.text_area :description, rows: 3, placeholder: "Descrizione pubblica o editoriale della experience." %>
        </div>

        <div class="field-group field-group-full" data-controller="easy-mde">
          <%= content_form.label :content, "Testo completo" %>
          <%= content_form.text_area :content, rows: 10, placeholder: "Contenuto completo della experience.", data: { easy_mde_target: "input" } %>
        </div>

        <div class="field-group">
          <%= content_form.label :published_at, "Data pubblicazione" %>
          <%= content_form.datetime_local_field :published_at %>
        </div>

        <div class="field-group">
          <%= content_form.label :thumb_url, "Thumb" %>
          <%= content_form.url_field :thumb_url %>
        </div>

        <div class="field-group">
          <%= content_form.label :banner_url, "Banner largo" %>
          <%= content_form.url_field :banner_url %>
        </div>

        <div class="field-group">
          <%= content_form.label :vertical_cover_url, "Cover verticale" %>
          <%= content_form.url_field :vertical_cover_url %>
        </div>

        <div class="field-group">
          <%= content_form.label :horizontal_cover_url, "Cover orizzontale" %>
          <%= content_form.url_field :horizontal_cover_url %>
        </div>

        <div class="field-group">
          <%= content_form.label :url_media_content, "Video / media" %>
          <%= content_form.url_field :url_media_content %>
        </div>

        <div class="field-group field-group-full">
          <%= content_form.label :mermaid, "Mermaid" %>
          <%= content_form.text_area :mermaid, rows: 4 %>
        </div>
      </div>
    <% end %>
  </div>

  <div class="form-actions">
    <%= link_to "Annulla", creator_port_experiences_path(@port), class: "btn btn-secondary" %>
    <%= form.submit experience.persisted? ? "Salva experience" : "Crea experience", class: "btn btn-primary" %>
  </div>
<% end %>
