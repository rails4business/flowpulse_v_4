<% content_for :title, "Carta nautica" %>

<section class="dashboard-shell">
  <div class="app-layout">
    <%= render "shared/app_sidebar" %>

    <div class="dashboard-card" style="display: flex; flex-direction: column; height: 100vh;" data-controller="sea-chart" data-sea-chart-add-mode-value="<%= params[:add_port].present? %>" data-sea-chart-edit-mode-value="<%= params[:add_port].present? %>">
      <div style="flex-shrink: 0;">
        <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1rem;">
          <div>
            <p class="eyebrow">Creator</p>
            <h1 style="margin-bottom: 0.5rem; max-width: none; white-space: nowrap;">Carta nautica</h1>
            <p>Il grande mare della tua offerta. Attiva <strong>Modifica</strong> quando vuoi aggiungere o sistemare i porti.</p>
            <% if params[:add_port].present? && @port.blank? %>
              <p style="margin: 0.75rem 0 0; display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.55rem 0.85rem; border-radius: 999px; background: #dbeafe; color: #1d4ed8; font-weight: 700; font-size: 0.9rem;">
                Clicca sulla mappa per scegliere il punto del nuovo porto.
              </p>
            <% end %>
          </div>
          <div style="display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap; justify-content: flex-end;">
            <button
              type="button"
              class="btn btn-secondary"
              data-sea-chart-target="modifyButton"
              data-action="click->sea-chart#toggleEditMode"
            >
              Modifica
            </button>
            <button
              type="button"
              class="btn btn-secondary"
              data-sea-chart-target="fullscreenButton"
              data-action="click->sea-chart#toggleFullscreen"
            >
              Full screen
            </button>
            <div data-sea-chart-target="editTools" hidden style="display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap;">
              <% if params[:add_port].present? %>
                <%= link_to "Annulla", creator_carta_nautica_path, class: "btn btn-secondary" %>
              <% else %>
              <%= link_to "+ Porto", creator_carta_nautica_path(add_port: true), class: "btn btn-primary" %>
              <% end %>
            </div>
          </div>
        </div>
      </div>

      <!-- SEA CHART AREA (Mappa in 2D) -->
      <div 
        class="sea-chart-container sea-chart-bg" 
        data-sea-chart-target="mapArea"
        data-action="click->sea-chart#mapClicked"
        style="flex-grow: 1; min-height: 500px; position: relative; background: #e0f2fe; border: 2px solid #bae6fd; border-radius: 12px; overflow: hidden; box-shadow: inset 0 0 20px rgba(0,0,0,0.05); user-select: none; transition: background-color 0.3s;"
      >
        <div class="sea-chart-wave-layer"></div>
        <div class="sea-chart-reef-layer" aria-hidden="true">
          <svg class="sea-chart-fish fish-a" viewBox="0 0 120 60">
            <path d="M14 30c14-15 32-22 50-20l18-8-4 14 16 14-16 14 4 14-18-8c-18 2-36-5-50-20z" />
            <circle cx="32" cy="25" r="2.5" />
          </svg>
          <svg class="sea-chart-fish fish-b" viewBox="0 0 120 60">
            <path d="M106 30c-14-15-32-22-50-20l-18-8 4 14-16 14 16 14-4 14 18-8c18 2 36-5 50-20z" />
            <circle cx="88" cy="25" r="2.5" />
          </svg>
          <svg class="sea-chart-fish fish-c" viewBox="0 0 120 60">
            <path d="M14 30c14-15 32-22 50-20l18-8-4 14 16 14-16 14 4 14-18-8c-18 2-36-5-50-20z" />
            <circle cx="32" cy="25" r="2.5" />
          </svg>
        </div>

        <!-- Griglia sottomarina -->
        <div style="position: absolute; inset: 0; background-image: radial-gradient(#93c5fd 1px, transparent 1px); background-size: 40px 40px; opacity: 0.38; pointer-events: none; z-index: 1;"></div>

        <!-- ROTTE E COLLEGAMENTI (SVG Layer invisibile) -->
        <svg style="position: absolute; inset: 0; width: 100%; height: 100%; pointer-events: none; z-index: 1;">
          <% @ports.each do |port| %>
            <% if port.brand_port.present? %>
              <% 
                # Calcolo stime per agganciare le linee vicino al centro (X+60, Y+40)
                p_x = port.brand_port.x.present? ? port.brand_port.x : 50 + ((port.brand_port.id || 1) * 20 % 300)
                p_y = port.brand_port.y.present? ? port.brand_port.y : 50 + ((port.brand_port.id || 1) * 35 % 300)
                
                c_x = port.x.present? ? port.x : 50 + ((port.id || 1) * 20 % 300)
                c_y = port.y.present? ? port.y : 50 + ((port.id || 1) * 35 % 300)
              %>
              <line 
                x1="<%= p_x + 60 %>" y1="<%= p_y + 40 %>" 
                x2="<%= c_x + 60 %>" y2="<%= c_y + 40 %>" 
                stroke="#475569" stroke-width="3" stroke-dasharray="8,8"
                opacity="0.4"
                data-sea-chart-target="line"
                data-source-id="<%= port.brand_port.id %>"
                data-target-id="<%= port.id %>"
              />
            <% end %>
          <% end %>
        </svg>

        <% if @ports.any? %>
          <% @ports.each do |port| %>
            <% 
              # Impostiamo posizioni a centro mappa se non sono ancora salvate
              x = port.x.present? ? port.x : 50 + ((port.id || 1) * 20 % 300)
              y = port.y.present? ? port.y : 50 + ((port.id || 1) * 35 % 300)
              own_color = port.color_config
              brand_color = port.brand_port&.color_config
              
              # La Libreria Araldica dei Segnaposti
              case port.port_kind
              when "brand"
                icon, island_kind_class = "⚓", "island-brand"
              when "map_port"
                icon, island_kind_class = "🧭", "island-map"
              when "blog"
                icon, island_kind_class = "📜", "island-blog"
              when "book"
                icon, island_kind_class = "🧰", "island-book"
              else
                icon, island_kind_class = "📍", "island-generic"
              end
            %>
            <div
              class="sea-chart-node sea-island <%= island_kind_class %>"
              data-sea-chart-target="node"
              data-action="mousedown->sea-chart#dragStart touchstart->sea-chart#dragStart"
              data-port-id="<%= port.id %>"
              style="position: absolute; left: <%= x %>px; top: <%= y %>px; background: radial-gradient(circle at 30% 20%, rgba(255,255,255,0.72), rgba(255,255,255,0) 42%), rgba(255,255,255,0.46);"
            >
              <% if port.brand_port.present? %>
                <div class="sea-island-flag" aria-hidden="true">
                  <span class="sea-island-flag-pole"></span>
                  <span class="sea-island-flag-cloth" style="background: linear-gradient(180deg, <%= brand_color[:stroke] %> 0%, <%= brand_color[:fill] %> 100%); border-color: <%= brand_color[:stroke] %>;"></span>
                </div>
              <% end %>
              <%= link_to "✎", edit_creator_port_path(port), style: "position: absolute; top: -8px; right: -8px; width: 28px; height: 28px; border-radius: 999px; background: #0f172a; color: white; text-decoration: none; display: inline-flex; align-items: center; justify-content: center; font-size: 0.9rem; box-shadow: 0 8px 18px rgba(15, 23, 42, 0.18);", data: { turbo: false, sea_chart_target: "editLink" }, hidden: true %>
              <div class="sea-island-shore">
                <div
                  class="sea-island-core"
                  style="border-color: <%= own_color[:stroke] %>; background: linear-gradient(180deg, <%= own_color[:fill] %> 0%, #fffdf7 100%); color: <%= own_color[:text] %>;"
                >
                  <div class="sea-island-icon" style="color: <%= own_color[:stroke] %>;"><%= icon %></div>
                  <strong class="sea-island-name"><%= port.name %></strong>
                </div>
              </div>
            </div>
          <% end %>
        <% else %>
          <div style="position: absolute; inset: 0; display: flex; justify-content: center; align-items: center; text-align: center; color: #0284c7;">
            <p>Il mare è calmo e inesplorato.<br><br>Costruisci navigando creando il tuo primo<br>brand, mappa, blog o libro.</p>
          </div>
        <% end %>
      </div>
      <p style="font-size: 0.8rem; color: #94a3b8; text-align: right; margin-top: 0.5rem;">In modalita' modifica puoi aggiungere nuovi porti, trascinare i nodi e aprire la modifica del singolo porto.</p>
    </div>
  </div>
</section>

<%= turbo_frame_tag "port_modal" do %>
  <%= render "creator/ports/modal", port: @port if @port.present? %>
<% end %>
