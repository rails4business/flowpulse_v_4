<% content_for :title, "Modifica station" %>

<section class="dashboard-shell">
  <div class="app-layout">
    <%= render "shared/app_sidebar" %>

    <div class="dashboard-card">
      <p class="eyebrow">Creator</p>
      <h1 class="page-title" style="margin-bottom: 0.35rem;">Modifica station: <%= @station.name %></h1>
      <p>Riallinea posizione, tipologia e interscambi della station.</p>

      <div class="dashboard-actions" style="margin-top: 2rem; background: #fff; padding: 2rem; border-radius: 8px; border: 1px solid #eee;">
        <%= render "form", station: @station %>
      </div>
    </div>
  </div>
</section>
