<% content_for :title, "Domini Web App" %>

<section class="dashboard-shell">
  <div class="app-layout">
    <%= render "shared/app_sidebar" %>

    <div class="dashboard-card">
      <div style="display: flex; justify-content: space-between; align-items: center; gap: 1rem; flex-wrap: wrap;">
        <div>
          <p class="eyebrow">Creator Webapp Domain</p>
          <h1 class="page-title" style="margin-bottom: 0.35rem;">Domini di <%= @brand_port.name %></h1>
        </div>
        <div style="display: flex; gap: 0.75rem;">
          <%= link_to "Torna al brand", creator_port_path(@brand_port), class: "btn btn-secondary" %>
          <%= link_to "+ Dominio", new_creator_port_webapp_domain_path(@brand_port), class: "btn btn-primary" %>
        </div>
      </div>

      <div style="margin-top: 1.5rem; display: grid; gap: 1rem;">
        <% @webapp_domains.each do |webapp_domain| %>
          <div class="dashboard-actions" style="background: #fff; padding: 1rem; border-radius: 16px; border: 1px solid #e2e8f0;">
            <div style="display: flex; justify-content: space-between; gap: 1rem; flex-wrap: wrap;">
              <div>
                <strong><%= webapp_domain.host %></strong>
                <p style="margin: 0.35rem 0 0; color: #475569;">Lingua: <%= webapp_domain.locale %> · Home: <%= webapp_domain.home_page_key.present? ? webapp_domain.home_page_key : "brand" %></p>
                <p style="margin: 0.35rem 0 0; font-size: 0.82rem; color: <%= webapp_domain.published? ? "#166534" : "#991b1b" %>;">
                  <strong><%= webapp_domain.published? ? "Pubblico attivo" : "Non pubblicato" %></strong>
                  · <%= webapp_domain.published? ? "Il resolver pubblico usa questo dominio." : "Finché non è pubblicato, la root pubblica lo ignora." %>
                </p>
              </div>
              <div style="display: flex; gap: 0.5rem; align-items: center;">
                <% if webapp_domain.primary? %><span class="btn btn-secondary" style="padding: 0.35rem 0.6rem;">Primary</span><% end %>
                <%= button_to(
                  webapp_domain.published? ? "Published" : "Draft",
                  toggle_published_creator_port_webapp_domain_path(@brand_port, webapp_domain),
                  method: :patch,
                  class: "btn btn-secondary",
                  form: {
                    style: "display: inline-block;",
                    data: (webapp_domain.published? ? { turbo_confirm: "Sei sicuro di voler riportare questo dominio in draft?" } : {})
                  },
                  style: "padding: 0.35rem 0.6rem; #{webapp_domain.published? ? "background: #dcfce7; border-color: #86efac; color: #166534;" : "background: #fee2e2; border-color: #fecaca; color: #991b1b;"}"
                ) %>
                <%= link_to "Modifica", edit_creator_port_webapp_domain_path(@brand_port, webapp_domain), class: "btn btn-secondary" %>
              </div>
            </div>
          </div>
        <% end %>

        <% if @webapp_domains.blank? %>
          <div class="dashboard-actions" style="background: #fff; padding: 1rem; border-radius: 16px; border: 1px dashed #cbd5e1;">
            Nessun dominio associato a questa web app.
          </div>
        <% end %>
      </div>
    </div>
  </div>
</section>
