<% content_for :title, "Modifica Dominio Web App" %>

<section class="dashboard-shell">
  <div class="app-layout">
    <%= render "shared/app_sidebar" %>

    <div class="dashboard-card">
      <div style="display: flex; justify-content: space-between; align-items: center; gap: 1rem; flex-wrap: wrap;">
        <div>
          <p class="eyebrow">Creator Webapp Domain</p>
          <h1 style="margin-bottom: 0.35rem; max-width: none; white-space: nowrap;">Modifica dominio: <%= @webapp_domain.host %></h1>
        </div>
        <%= button_to "Elimina dominio", creator_port_webapp_domain_path(@brand_port, @webapp_domain), method: :delete, form: { data: { turbo_confirm: "Sei sicuro di voler eliminare questo dominio?" } }, class: "btn btn-danger", style: "background: #dc2626; color: white; border: none;" %>
      </div>

      <div class="dashboard-actions" style="margin-top: 2rem; background: #fff; padding: 2rem; border-radius: 16px; border: 1px solid #e2e8f0;">
        <%= render "form", brand_port: @brand_port, webapp_domain: @webapp_domain %>
      </div>
    </div>
  </div>
</section>
