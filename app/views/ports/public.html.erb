<% content_for :title, @webapp_domain&.seo_title.presence || @webapp_domain&.title.presence || @port.name %>

<section
  style="
    --brand-header-bg: <%= @webapp_domain&.header_bg_color.presence || "#0f172a" %>;
    --brand-header-text: <%= @webapp_domain&.header_text_color.presence || "#f8fafc" %>;
    --brand-accent: <%= @webapp_domain&.accent_color.presence || "#0f766e" %>;
    --brand-background: <%= @webapp_domain&.background_color.presence || "#f8fafc" %>;
    min-height: 100vh;
    background: var(--brand-background);
  "
>
  <%= render "shared/public_nav",
    brand_title: (@webapp_domain&.title.presence || @brand_port.name),
    logo_horizontal_url: @webapp_domain&.horizontal_logo_url,
    logo_square_url: @webapp_domain&.square_logo_url,
    home_path: root_path,
    accent_color: (@webapp_domain&.accent_color.presence || "#0f766e"),
    background_color: (@webapp_domain&.background_color.presence || "#f8fafc"),
    header_bg_color: (@webapp_domain&.header_bg_color.presence || "#ffffff"),
    header_text_color: (@webapp_domain&.header_text_color.presence || "#0f172a"),
    nav_links: [{ label: "Home", href: root_path }] + @brand_nav_routes.map { |route| { label: route.target_port.name, href: "#brand-port-#{route.target_port.id}" } } %>

  <main style="min-height: calc(100vh - 78px); width: 100%;"></main>

  <% if development_domain_simulation_active? %>
    <footer style="padding: 0.85rem 1.25rem 1.1rem; text-align: center;">
      <span style="display: inline-flex; align-items: center; gap: 0.35rem; padding: 0.35rem 0.6rem; border-radius: 999px; background: #e0f2fe; color: #0c4a6e; font-size: 0.72rem; font-weight: 700;">
        Dev domain: <code style="font-size: 0.72rem; font-weight: 800;"><%= resolved_domain_host %></code> · Port <code style="font-size: 0.72rem; font-weight: 800;"><%= @port.id %></code>
      </span>
    </footer>
  <% end %>

  <% if @webapp_domain&.custom_css.present? %>
    <style><%= @webapp_domain.custom_css.html_safe %></style>
  <% end %>
</section>
