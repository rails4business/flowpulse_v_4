<% content_for :title, "Le mie mappe percorse" %>

<section class="dashboard-shell">
  <div class="app-layout">
    <%= render "shared/app_sidebar" %>

    <div class="dashboard-card">
      <p class="eyebrow">Viaggiatore</p>
      <h1 style="margin-bottom: 0.35rem; max-width: none; white-space: nowrap;">Le mie mappe percorse</h1>
      <p>
        Questa vista raccogliera' i journey vissuti, i trail attraversati e le mappe personali costruite dal viaggiatore
        intorno a un bisogno, a un miglioramento o a una ricerca di conoscenza.
      </p>

      <div class="dashboard-section">
        <h2>Tre ambiti percorso</h2>
        <div class="dashboard-grid">
          <article class="dashboard-panel dashboard-panel-blue">
            <span class="dashboard-panel-kicker">Ambito 01</span>
            <h3>Salute / principi</h3>
            <p>Percorsi orientati a salute, principi di base, benessere e fondamenta del cambiamento.</p>
          </article>
          <article class="dashboard-panel dashboard-panel-green">
            <span class="dashboard-panel-kicker">Ambito 02</span>
            <h3>Relazione / lavoro / risorse</h3>
            <p>Percorsi legati a relazione, lavoro, organizzazione, risorse e vita operativa.</p>
          </article>
          <article class="dashboard-panel dashboard-panel-red">
            <span class="dashboard-panel-kicker">Ambito 03</span>
            <h3>Formazione / eventi</h3>
            <p>Percorsi orientati a conoscenza, eventi, crescita formativa e trasmissione di metodo.</p>
          </article>
        </div>
      </div>

      <div class="admin-section">
        <h2>Riferimento attuale</h2>
        <div class="admin-list">
          <article class="admin-list-item">
            <div class="admin-list-copy">
              <strong>Mockup statico 1Impegno</strong>
              <p>Dashboard personale del viaggiatore da migrare progressivamente.</p>
            </div>
            <div class="admin-list-actions">
              <a href="/flowpulse_v_4/4_1impegno.html" class="btn btn-secondary">Apri riferimento</a>
            </div>
          </article>
        </div>
      </div>
    </div>
  </div>
</section>
