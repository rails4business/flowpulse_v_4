<% content_for :title, "Giornata Tipo" %>

<section class="dashboard-shell">
  <div class="app-layout">
    <%= render "shared/app_sidebar" %>

    <div class="dashboard-card" style="flex-grow: 1; padding: 3rem; overflow-y: auto; background-color: var(--founder-paper, #fffdf8);">
      <div style="margin-bottom: 2rem; border-bottom: 1px solid #f1f5f9; padding-bottom: 1.5rem;">
        <h1 class="page-title" style="margin: 0; font-size: 1.5rem; font-weight: 700; color: #0f172a;">
          Giornata Tipo
        </h1>
        <p style="margin: 0.5rem 0 0 0; font-size: 0.95rem; color: #64748b; max-width: 700px; line-height: 1.5;">
          L'organizzazione focale della tua singola giornata: slot orari e routine.
        </p>
      </div>

      <!-- Futuro inserimento slot orari o routine giornaliera -->
      <div style="margin-top: 2rem; padding: 2rem; border: 2px dashed #cbd5e1; border-radius: 8px; text-align: center; color: #94a3b8;">
        Area in costruzione per la timeline della singola giornata.
      </div>
    </div>
  </div>
</section>
