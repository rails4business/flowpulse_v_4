<% step = local_assigns.fetch(:item) %>
<% requires_membership = local_assigns.fetch(:requires_membership, false) %>
<% module_categories = %w[academy_module module_academy module_accademy] %>
<% path_children = Array(step[:children]).reject { |child| module_categories.include?(child[:taxbranch]&.slug_category.to_s) } %>
<% cover_url = "https://ik.imagekit.io/posturacorretta/immagini_brand/igiene-posturale.png?updatedAt=1763752348993" %>

<section class="space-y-3">
  <div class="px-1">
    <div class="text-xs uppercase tracking-[0.22em] text-slate-400">Percorso</div>
    <h2 class="mt-1 text-2xl md:text-3xl font-black tracking-tight text-slate-900"><%= step[:title] %></h2>
    <% if step[:subtitle].present? %>
      <p class="mt-1 text-sm text-slate-500"><%= step[:subtitle] %></p>
    <% end %>
  </div>

  <% if path_children.any? %>
    <div class="space-y-3">
      <% path_children.each do |child| %>
        <% child_modules = Array(child[:children]).select { |node| module_categories.include?(node[:taxbranch]&.slug_category.to_s) } %>
        <% progress = child[:step_progress_percent].to_i.clamp(0, 100) %>
        <% total_lessons = [child[:step_progress_total].to_i, 1].max %>
        <% done_lessons = [[child[:step_progress_completed].to_i, 0].max, total_lessons].min %>
        <% mode_label = child[:mode_label].presence || "Professionista" %>
        <% tile_classes = "block w-full text-left px-4 py-4 rounded-2xl border bg-white hover:bg-slate-50 transition-all shadow-sm" %>
        <% tile_classes += if child[:status_key] == :completed
                             " border-emerald-200 ring-2 ring-emerald-200/40 bg-emerald-50/40"
                           elsif child[:status_key] == :in_progress || child[:status_key] == :scheduled
                             " border-primary ring-2 ring-primary/10 bg-blue-50/50"
                           else
                             " border-slate-200"
                           end %>

        <% card_inner = capture do %>
          <div class="flex items-start justify-between gap-3 mb-3">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-white shrink-0 relative ring-2 ring-slate-200/80 p-1">
                <div class="w-full h-full rounded-full overflow-hidden bg-slate-100">
                  <img src="<%= cover_url %>"
                       alt="<%= child[:title] %>"
                       class="w-full h-full object-cover rounded-full origin-center"
                       style="transform: scale(2.35); clip-path: circle(24% at 50% 50%);"
                       loading="lazy"
                       onerror="this.classList.add('hidden'); this.parentElement.nextElementSibling.classList.remove('hidden');">
                </div>
                <div class="hidden absolute inset-1 rounded-full bg-gradient-to-br from-blue-400 to-blue-600 text-white items-center justify-center flex">
                  <span class="material-symbols-outlined text-[20px] leading-none">accessibility_new</span>
                </div>
              </div>
              <div>
                <div class="font-bold text-slate-800 text-sm leading-tight line-clamp-2"><%= child[:title] %></div>
                <div class="text-[10px] text-slate-500 mt-0.5">PosturaCorretta</div>
              </div>
            </div>
          </div>

          <div class="space-y-3">
            <div class="flex items-center justify-between text-xs">
              <div class="inline-flex items-center px-2 py-0.5 rounded bg-white border border-slate-100 text-slate-400 font-medium uppercase tracking-wider text-[9px]"><%= mode_label %></div>
              <div class="font-semibold text-primary"><%= progress %>%</div>
            </div>
            <div class="h-1.5 rounded-full bg-slate-100 overflow-hidden">
              <div class="h-1.5 bg-primary/80 transition-all duration-500" style="width:<%= progress %>%"></div>
            </div>
            <div class="text-[10px] text-slate-400 text-right">
              <%= done_lessons %> di <%= total_lessons %> lezioni
            </div>
          </div>
        <% end %>

        <% modal_id = "academy-path-modal-#{child[:taxbranch]&.id || child.object_id}" %>
        <div>
          <button type="button"
                  class="<%= tile_classes %> w-full"
                  data-academy-path-open="<%= modal_id %>"
                  aria-haspopup="dialog"
                  aria-controls="<%= modal_id %>">
            <%= card_inner %>
          </button>

          <div id="<%= modal_id %>"
               class="fixed inset-0 z-[90] hidden items-center justify-center bg-slate-900/55 p-4"
               role="dialog"
               aria-modal="true"
               aria-label="<%= child[:title] %>">
            <div class="w-full max-w-6xl max-h-[88vh] overflow-y-auto rounded-2xl border border-slate-200 bg-white shadow-2xl">
              <div class="sticky top-0 z-10 flex items-center justify-between gap-3 border-b border-slate-100 bg-white px-4 py-3">
                <div>
                  <div class="text-[10px] uppercase tracking-[0.2em] text-slate-400 font-bold">Percorso</div>
                  <h3 class="text-base md:text-lg font-black text-slate-900"><%= child[:title] %></h3>
                </div>
                <button type="button"
                        class="inline-flex items-center justify-center rounded-lg border border-slate-200 bg-white px-3 py-1.5 text-xs font-semibold text-slate-600 hover:bg-slate-50"
                        data-academy-path-close="<%= modal_id %>">
                  Chiudi
                </button>
              </div>
              <div class="p-4 space-y-3">
                <% if child_modules.any? %>
                  <% child_modules.each do |module_node| %>
                    <%= render "dashboard/academy_module", item: module_node, requires_membership: requires_membership %>
                  <% end %>
                <% else %>
                  <div class="rounded-xl border border-dashed border-slate-300 bg-slate-50 px-4 py-5 text-sm text-slate-500">
                    Nessun modulo collegato a questo path.
                  </div>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</section>

<script nonce="<%= content_security_policy_nonce %>">
  (function() {
    if (window.__academyPathModalBound) return;
    window.__academyPathModalBound = true;

    document.addEventListener("click", function(event) {
      var openTrigger = event.target.closest("[data-academy-path-open]");
      if (openTrigger) {
        var modalId = openTrigger.getAttribute("data-academy-path-open");
        var modal = modalId ? document.getElementById(modalId) : null;
        if (modal) {
          modal.classList.remove("hidden");
          modal.classList.add("flex");
          document.body.classList.add("overflow-hidden");
        }
        return;
      }

      var closeTrigger = event.target.closest("[data-academy-path-close]");
      if (closeTrigger) {
        var closeId = closeTrigger.getAttribute("data-academy-path-close");
        var closeModal = closeId ? document.getElementById(closeId) : null;
        if (closeModal) {
          closeModal.classList.add("hidden");
          closeModal.classList.remove("flex");
          document.body.classList.remove("overflow-hidden");
        }
        return;
      }

      var overlay = event.target.closest("[role='dialog'][aria-modal='true']");
      if (overlay && event.target === overlay) {
        overlay.classList.add("hidden");
        overlay.classList.remove("flex");
        document.body.classList.remove("overflow-hidden");
      }
    });

    document.addEventListener("keydown", function(event) {
      if (event.key !== "Escape") return;
      var opened = document.querySelector("[role='dialog'][aria-modal='true'].flex");
      if (!opened) return;
      opened.classList.add("hidden");
      opened.classList.remove("flex");
      document.body.classList.remove("overflow-hidden");
    });
  })();
</script>
