<div class="min-h-screen bg-slate-50">
  <div class="mx-auto max-w-6xl px-6 py-8">
    <div class="mb-6 flex flex-wrap items-start justify-between gap-4">
      <div>
        <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-500">Journey Trenino</p>
        <h1 class="mt-1 text-3xl font-bold text-slate-900"><%= @journey.title %></h1>
        <div class="mt-3 flex flex-wrap gap-2 text-xs">
          <span class="inline-flex items-center rounded-full border border-slate-200 bg-white px-3 py-1 font-semibold text-slate-700">
            Phase: <%= @journey.phase_label %>
          </span>
          <span class="inline-flex items-center rounded-full border border-slate-200 bg-white px-3 py-1 font-semibold text-slate-700">
            Mode: <%= @journey.mode_label %>
          </span>
          <% if @journey.kind.present? %>
            <span class="inline-flex items-center rounded-full border border-slate-200 bg-white px-3 py-1 font-semibold text-slate-700">
              Kind: <%= @journey.kind.humanize %>
            </span>
          <% end %>
        </div>
      </div>

      <div class="flex flex-wrap gap-2">
        <%= link_to "Journey", journey_path(@journey), class: "inline-flex items-center rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50" %>
        <%= link_to "Modifica", edit_journey_path(@journey), class: "inline-flex items-center rounded-lg bg-slate-900 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-800" %>
        <%= link_to "+ Vagone", new_journey_eventdate_path(@journey), class: "inline-flex items-center rounded-lg bg-blue-600 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-500" %>
      </div>
    </div>

    <% if @journey.template_journey.present? %>
      <div class="mb-6 rounded-2xl border border-violet-200 bg-violet-50 px-4 py-3 text-sm text-violet-900">
        Deriva da template:
        <%= link_to @journey.template_journey.title, train_journey_path(@journey.template_journey), class: "font-semibold underline" %>
      </div>
    <% end %>

    <% if @eventdates.blank? %>
      <div class="rounded-2xl border border-dashed border-slate-300 bg-white px-6 py-10 text-center text-slate-500">
        Nessun vagone nel trenino. Aggiungi il primo `Eventdate` per costruire il percorso.
      </div>
    <% else %>
      <div class="space-y-4">
        <% @eventdates.each_with_index do |eventdate, index| %>
          <div class="relative rounded-2xl border border-slate-200 bg-white px-5 py-4 shadow-sm">
            <% unless index == @eventdates.size - 1 %>
              <div class="absolute left-9 top-full h-4 w-px bg-slate-300"></div>
            <% end %>

            <div class="flex items-start gap-4">
              <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-slate-900 text-sm font-bold text-white">
                <%= index + 1 %>
              </div>

              <div class="min-w-0 flex-1">
                <div class="flex flex-wrap items-start justify-between gap-3">
                  <div>
                    <h2 class="text-lg font-semibold text-slate-900">
                      <%= eventdate.description.presence || "Vagone ##{eventdate.id}" %>
                    </h2>
                    <div class="mt-2 flex flex-wrap gap-2 text-xs">
                      <% if eventdate.date_start.present? %>
                        <span class="inline-flex items-center rounded-full bg-slate-100 px-2.5 py-1 font-medium text-slate-700">
                          <%= l(eventdate.date_start, format: :short) %>
                        </span>
                      <% end %>
                      <% if eventdate.status.present? %>
                        <span class="inline-flex items-center rounded-full bg-slate-100 px-2.5 py-1 font-medium text-slate-700">
                          <%= eventdate.status.humanize %>
                        </span>
                      <% end %>
                      <% if eventdate.taxbranch.present? %>
                        <span class="inline-flex items-center rounded-full bg-blue-50 px-2.5 py-1 font-medium text-blue-700">
                          Taxbranch: <%= eventdate.taxbranch.display_label %>
                        </span>
                      <% end %>
                    </div>
                  </div>

                  <div class="flex flex-wrap gap-2">
                    <%= link_to "Apri", eventdate_path(eventdate), class: "inline-flex items-center rounded-lg border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold text-slate-700 hover:bg-slate-50" %>
                    <%= link_to "Modifica", edit_eventdate_path(eventdate), class: "inline-flex items-center rounded-lg border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold text-slate-700 hover:bg-slate-50" %>
                  </div>
                </div>

                <% if eventdate.child_journey.present? %>
                  <div class="mt-4 rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3">
                    <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-emerald-700">Sottoprocesso aperto da questo vagone</p>
                    <div class="mt-1 flex flex-wrap items-center justify-between gap-3">
                      <div>
                        <p class="text-sm font-semibold text-emerald-900"><%= eventdate.child_journey.title %></p>
                        <p class="mt-1 text-xs text-emerald-800">
                          Phase: <%= eventdate.child_journey.phase_label %>
                          <% if eventdate.child_journey.mode.present? %>
                            · Mode: <%= eventdate.child_journey.mode_label %>
                          <% end %>
                        </p>
                      </div>
                      <div class="flex flex-wrap gap-2">
                        <%= link_to "Apri trenino", train_journey_path(eventdate.child_journey), class: "inline-flex items-center rounded-lg bg-emerald-700 px-3 py-1.5 text-xs font-semibold text-white hover:bg-emerald-600" %>
                        <%= link_to "Journey", journey_path(eventdate.child_journey), class: "inline-flex items-center rounded-lg border border-emerald-300 bg-white px-3 py-1.5 text-xs font-semibold text-emerald-800 hover:bg-emerald-100" %>
                      </div>
                    </div>
                  </div>
                <% else %>
                  <div class="mt-4 rounded-xl border border-dashed border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-500">
                    Nessun sottoprocesso collegato a questo vagone.
                  </div>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
