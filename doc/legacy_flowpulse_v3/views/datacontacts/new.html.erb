<% step_flow = params[:step_taxbranch_id].present? %>
<% content_for :title, step_flow ? "Completa il tuo profilo" : "New datacontact" %>

<div class="md:w-2/3 w-full">
  <% unless step_flow %>
    <h1 class="font-bold text-4xl">New datacontact</h1>
  <% end %>

  <%= render "form", datacontact: @datacontact %>

  <% unless step_flow %>
    <%= link_to "Back to datacontacts", datacontacts_path, class: "w-full sm:w-auto text-center mt-2 sm:mt-0 sm:ml-2 rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
  <% end %>
</div>
