<section class="mx-auto w-full max-w-4xl px-4 py-8 space-y-4">
  <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
    <p class="text-xs uppercase tracking-[0.2em] text-slate-400">Activity</p>
    <h1 class="mt-1 text-xl font-black text-slate-900"><%= @post.title.presence || @taxbranch&.slug_label %></h1>
    <p class="mt-1 text-sm text-slate-500">Attivita aperta per questo contenuto.</p>

    <div class="mt-4 grid grid-cols-1 md:grid-cols-3 gap-3 text-sm">
      <div class="rounded-xl border border-slate-200 bg-slate-50 p-3">
        <div class="text-[10px] uppercase tracking-wide text-slate-500">Stato</div>
        <div class="mt-1 font-semibold text-slate-800"><%= @activity.status %></div>
      </div>
      <div class="rounded-xl border border-slate-200 bg-slate-50 p-3">
        <div class="text-[10px] uppercase tracking-wide text-slate-500">Tipo</div>
        <div class="mt-1 font-semibold text-slate-800"><%= @activity.kind %></div>
      </div>
      <div class="rounded-xl border border-slate-200 bg-slate-50 p-3">
        <div class="text-[10px] uppercase tracking-wide text-slate-500">Data</div>
        <div class="mt-1 font-semibold text-slate-800"><%= l(@activity.occurred_at, format: :short) rescue @activity.occurred_at %></div>
      </div>
    </div>

    <% if @activity_level_info.present? %>
      <div class="mt-5 rounded-xl border p-4 <%= @activity_level_info[:badge_class] %>">
        <div class="flex items-center justify-between gap-3">
          <h2 class="text-sm font-bold uppercase tracking-wide">Risultato Test Mobilita</h2>
          <span class="inline-flex items-center rounded-full px-2 py-0.5 text-[11px] font-bold <%= @activity_level_info[:chip_class] %>">
            <%= (@activity.level_code.presence || @activity_level_info[:code]).to_s.upcase %>
          </span>
        </div>
        <p class="mt-1 text-base font-black"><%= "#{@activity_level_info[:emoji]} #{@activity_level_info[:label]}" %></p>
        <p class="mt-1 text-sm font-semibold">
          Punteggio: <%= @activity.score_total || 0 %>/<%= @activity.score_max || 0 %>
          <% if @activity_level_info[:min].present? && @activity_level_info[:max].present? %>
            · Range: <%= @activity_level_info[:min] %>-<%= @activity_level_info[:max] %>
          <% end %>
        </p>
        <% if @activity_level_info[:interpretation].present? %>
          <p class="mt-1 text-sm"><strong>Interpretazione:</strong> <%= @activity_level_info[:interpretation] %></p>
        <% end %>
        <% if @activity_level_info[:recommendation].present? %>
          <p class="mt-1 text-sm"><strong>Consiglio:</strong> <%= @activity_level_info[:recommendation] %></p>
        <% end %>
      </div>
    <% end %>

    <% if @answers_detailed.present? %>
      <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50/60 p-4">
        <div class="flex items-center justify-between gap-3">
          <h2 class="text-sm font-bold text-slate-900">Questionario</h2>
          <% if @questionnaire_snapshot.present? %>
            <span class="text-[11px] text-slate-500">
              <%= @questionnaire_snapshot["title"].presence || "Snapshot" %>
              <% if @questionnaire_snapshot["version"].present? %>
                · <%= @questionnaire_snapshot["version"] %>
              <% end %>
            </span>
          <% end %>
        </div>
        <div class="mt-3 space-y-2">
          <% @answers_detailed.each_with_index do |entry, idx| %>
            <% question_text = entry["question"].to_s.presence || entry["code"].to_s %>
            <% value = entry["label"].presence || entry["value"] %>
            <% value_text = value.is_a?(Array) ? value.join(", ") : value.to_s %>
            <div class="rounded-lg border border-slate-200 bg-white px-3 py-2">
              <p class="text-[11px] uppercase tracking-wide text-slate-500">Domanda <%= idx + 1 %></p>
              <p class="mt-0.5 text-sm font-medium text-slate-900"><%= question_text %></p>
              <p class="mt-1 text-sm text-slate-700"><%= value_text.presence || "—" %></p>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <div class="mt-4 flex flex-wrap items-center gap-2">
      <%= link_to "Apri contenuto", post_path(@post), class: "inline-flex items-center rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-white hover:brightness-110" %>
      <%= link_to "Torna dashboard", dashboard_home_path(tab: "academy"), class: "inline-flex items-center rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50" %>
    </div>
  </div>
</section>
