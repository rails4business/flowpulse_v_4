<section class="mx-auto w-full max-w-3xl px-4 py-8">
  <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
    <div class="mb-4">
      <p class="text-xs uppercase tracking-[0.2em] text-slate-400">Nuova attivita</p>
      <h1 class="mt-1 text-xl font-black text-slate-900"><%= @post.title.presence || @taxbranch&.slug_label %></h1>
      <p class="mt-1 text-sm text-slate-500">Gestisci il passaggio di attivazione per questo contenuto.</p>
    </div>

    <div class="mb-4 rounded-xl border border-blue-100 bg-blue-50/60 p-3">
      <p class="text-xs text-slate-700">Contenuto collegato</p>
      <%= link_to "Apri post", post_path(@post), class: "mt-1 inline-flex items-center rounded-lg bg-white px-3 py-1.5 text-xs font-semibold text-primary border border-primary/20 hover:bg-primary/5" %>
    </div>

    <%= form_with model: @activity, url: post_activities_path(@post), class: "space-y-4" do |f| %>
      <% if @activity.errors.any? %>
        <div class="rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-700">
          <%= @activity.errors.full_messages.to_sentence %>
        </div>
      <% end %>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        <div>
          <%= f.label :kind, class: "block text-xs font-semibold text-slate-600" %>
          <%= f.select :kind, Activity.kinds.keys.map { |k| [k.humanize, k] }, {}, class: "mt-1 w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm" %>
        </div>
        <div>
          <%= f.label :status, class: "block text-xs font-semibold text-slate-600" %>
          <%= f.select :status, Activity.statuses.keys.map { |k| [k.humanize, k] }, {}, class: "mt-1 w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm" %>
        </div>
      </div>

      <div>
        <%= f.label :occurred_at, class: "block text-xs font-semibold text-slate-600" %>
        <%= f.datetime_local_field :occurred_at, value: Time.current.strftime("%Y-%m-%dT%H:%M"), class: "mt-1 w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm" %>
      </div>

      <div class="flex items-center gap-2 pt-2">
        <%= f.submit "Salva attivita", class: "inline-flex items-center rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-white hover:brightness-110" %>
        <%= link_to "Torna alla dashboard", dashboard_home_path(tab: "academy"), class: "inline-flex items-center rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50" %>
      </div>
    <% end %>
  </div>
</section>
