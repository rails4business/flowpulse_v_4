  // --------------------------
  // STORAGE (NEW: mode is per module)
  // --------------------------
  const LS_PREFIX = "pc.module_progress.v2.";
  const LS_PATH_PROFILE = "pc.path_profile.v1";

  function loadPathProfile() {
    const saved = (localStorage.getItem(LS_PATH_PROFILE) || "verde").toLowerCase();
    return ["rosso", "verde", "blu"].includes(saved) ? saved : "verde";
  }

  function savePathProfile(value) {
    localStorage.setItem(LS_PATH_PROFILE, value);
  }

  function isRedPath() {
    return loadPathProfile() === "rosso";
  }

  function renderCertificationSection(m, prog) {
    const section = $("moduleCertificationSection");
    if (!section) return;
    section.classList.remove("hidden");

    const state = finalCheckState(m, prog);
    const price = fmtEUR(m.pricing?.final_check ?? FINAL_CHECK_DEFAULT_PRICE);
    const desc = $("moduleCertificationDesc");
    const badgeEl = $("moduleCertificationBadge");
    const bookBtn = $("certBookBtn");
    const doneBtn = $("certDoneBtn");
    const resetBtn = $("certResetBtn");

    if (desc) {
      desc.textContent = `Certificazione facoltativa a pagamento (${price}). Disponibile dopo il completamento delle lezioni del modulo.`;
    }

    if (badgeEl) {
      if (state === "locked") {
        badgeEl.className = "text-[10px] px-2 py-1 rounded-lg border bg-slate-100 text-slate-500 uppercase tracking-wide";
        badgeEl.textContent = "Bloccata";
      } else if (state === "booked") {
        badgeEl.className = "text-[10px] px-2 py-1 rounded-lg border bg-amber-50 text-amber-700 border-amber-200 uppercase tracking-wide";
        badgeEl.textContent = "Prenotata";
      } else if (state === "completed") {
        badgeEl.className = "text-[10px] px-2 py-1 rounded-lg border bg-emerald-50 text-emerald-700 border-emerald-200 uppercase tracking-wide";
        badgeEl.textContent = "Completata";
      } else {
        badgeEl.className = "text-[10px] px-2 py-1 rounded-lg border bg-blue-50 text-blue-700 border-blue-200 uppercase tracking-wide";
        badgeEl.textContent = "Disponibile";
      }
    }

    const disabled = state === "locked";
    [bookBtn, doneBtn, resetBtn].forEach((btn) => {
      if (!btn) return;
      btn.disabled = disabled;
      btn.classList.toggle("opacity-50", disabled);
      btn.classList.toggle("cursor-not-allowed", disabled);
    });

    if (bookBtn) {
      bookBtn.textContent = state === "booked" ? "Annulla prenotazione" : "Prenota";
    }
  }

  function enforcePathRulesOnAllModules(path) {
    if (path !== "rosso") return;
    MODULES.forEach((mod) => {
      const prog = loadProgress(mod.id);
      if (prog.mode !== "professionista") {
        prog.mode = "professionista";
        saveProgress(mod.id, prog);
      }
    });
  }

  function renderPathProfileUI() {
    const path = loadPathProfile();
    if ($("pathRosso")) $("pathRosso").checked = path === "rosso";
    if ($("pathVerde")) $("pathVerde").checked = path === "verde";
    if ($("pathBlu")) $("pathBlu").checked = path === "blu";
    if ($("pathProfileSelect")) $("pathProfileSelect").value = path;

    ["pathRosso", "pathVerde", "pathBlu"].forEach((id) => {
      const input = $(id);
      if (!input) return;
      input.disabled = false;
      input.closest("label")?.classList.remove("opacity-60");
